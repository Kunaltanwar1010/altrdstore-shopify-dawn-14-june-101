{% doc %}
  @prompt
    create a scrolling marquee to showcase the brand offers, tag line
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .ai-marquee-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-marquee-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: 0 {{ block.settings.item_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
  }

  .ai-marquee-separator-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.separator_size }}px;
    height: {{ block.settings.separator_size }}px;
    background-color: {{ block.settings.separator_color }};
    border-radius: 50%;
    margin: 0 {{ block.settings.item_spacing }}px;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-marquee-wrapper-{{ ai_gen_id }}:hover {
    animation-play-state: {% if block.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<marquee-banner-{{ ai_gen_id }} class="ai-marquee-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-content-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign offer_key = 'offer_' | append: i
          assign offer_text = block.settings[offer_key]
        %}
        {% if offer_text != blank %}
          <span class="ai-marquee-item-{{ ai_gen_id }}">{{ offer_text }}</span>
          {% if block.settings.show_separator %}
            <span class="ai-marquee-separator-{{ ai_gen_id }}"></span>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
    <div class="ai-marquee-content-{{ ai_gen_id }}" aria-hidden="true">
      {% for i in (1..3) %}
        {% liquid
          assign offer_key = 'offer_' | append: i
          assign offer_text = block.settings[offer_key]
        %}
        {% if offer_text != blank %}
          <span class="ai-marquee-item-{{ ai_gen_id }}">{{ offer_text }}</span>
          {% if block.settings.show_separator %}
            <span class="ai-marquee-separator-{{ ai_gen_id }}"></span>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</marquee-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-marquee-wrapper-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-marquee-content-{{ ai_gen_id }}');
        
        if (this.wrapper && this.content) {
          this.adjustSpeed();
        }
      }

      adjustSpeed() {
        const contentWidth = this.content.offsetWidth;
        const speed = {{ block.settings.scroll_speed }};
        const duration = (contentWidth / 100) * speed;
        this.wrapper.style.animationDuration = duration + 's';
      }
    }

    customElements.define('marquee-banner-{{ ai_gen_id }}', MarqueeBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Scrolling marquee",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "offer_1",
      "label": "Offer 1",
      "default": "Free shipping on orders over ₹999"
    },
    {
      "type": "text",
      "id": "offer_2",
      "label": "Offer 2",
      "default": "Shop now and save up to 30%"
    },
    {
      "type": "text",
      "id": "offer_3",
      "label": "Offer 3",
      "default": "New arrivals every week"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator",
      "default": true
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "separator_size",
      "label": "Separator size",
      "min": 4,
      "max": 12,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "s",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Scrolling marquee"
    }
  ]
}
{% endschema %}
