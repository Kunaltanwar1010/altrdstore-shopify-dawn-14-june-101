{%- liquid
  assign bg = section.settings.bg_color     | default: '#0B0B0B'
  assign tx = section.settings.text_color   | default: '#F4EFE6'
  assign ac = section.settings.accent_color | default: '#E8FF52'
  assign current_year = 'now' | date: '%Y'
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --af-bg: {{ bg }};
    --af-tx: {{ tx }};
    --af-ac: {{ ac }};
    --af-muted: {{ tx }}8c;   /* ~55% */
    --af-faint: {{ tx }}26;   /* ~15% */
  }
  .altrd-footer {
    background: var(--af-bg);
    color: var(--af-tx);
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* Newsletter band */
  .altrd-footer__news {
    border-bottom: 1px solid var(--af-faint);
    padding: {{ section.settings.padding_top }}px 0 3rem;
  }
  .altrd-footer__news-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .altrd-footer__news-text { max-width: 34rem; }
  .altrd-footer__news-heading {
    font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 0.95;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
  }
  .altrd-footer__news-sub {
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--af-muted);
    margin: 0;
  }
  .altrd-footer__form { flex: 1 1 22rem; max-width: 30rem; }
  .altrd-footer__form-row {
    display: flex;
    border-bottom: 1.5px solid var(--af-tx);
  }
  .altrd-footer__input {
    flex: 1 1 auto;
    background: transparent;
    border: 0;
    color: var(--af-tx);
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 1rem;
    padding: 0.75rem 0.25rem;
    outline: none;
  }
  .altrd-footer__input::placeholder { color: var(--af-muted); }
  .altrd-footer__submit {
    flex-shrink: 0;
    background: transparent;
    border: 0;
    color: var(--af-tx);
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0 0.5rem;
    cursor: pointer;
    transition: color 0.18s ease;
  }
  .altrd-footer__submit:hover { color: var(--af-ac); }
  .altrd-footer__form-note {
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 0.8125rem;
    margin: 0.75rem 0 0;
    color: var(--af-ac);
  }

  /* Main grid */
  .altrd-footer__grid {
    display: grid;
    grid-template-columns: 1.4fr repeat({{ section.blocks.size | at_least: 1 }}, minmax(0, 1fr));
    gap: 3rem 3.5rem;
    padding: 3.5rem 0;
  }
  .altrd-footer__brandcol { max-width: 22rem; }
  .altrd-footer__logo-img { display: block; height: auto; margin-bottom: 1.25rem; }
  .altrd-footer__logo-text {
    font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
    font-size: 2.25rem;
    line-height: 1;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }
  .altrd-footer__tagline {
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--af-muted);
    margin: 0 0 1.5rem;
  }

  .altrd-footer__col-heading {
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--af-ac);
    margin: 0 0 1.25rem;
  }
  .altrd-footer__nav-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .altrd-footer__nav-link {
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 0.9375rem;
    color: var(--af-muted);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .altrd-footer__nav-link:hover { color: var(--af-tx); }

  /* Social */
  .altrd-footer__social { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .altrd-footer__social-link {
    width: 2.5rem; height: 2.5rem;
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--af-faint);
    color: var(--af-tx);
    border-radius: 50%;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }
  .altrd-footer__social-link:hover { background: var(--af-ac); color: #0B0B0B; border-color: var(--af-ac); }
  .altrd-footer__social-link svg { width: 1.05rem; height: 1.05rem; }

  /* Giant wordmark */
  .altrd-footer__wordmark {
    font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
    font-weight: 400;
    line-height: 0.8;
    text-transform: uppercase;
    text-align: center;
    letter-spacing: -0.01em;
    margin: 0;
    padding: 1.5rem 0 2.5rem;
    color: var(--af-tx);
    white-space: nowrap;
    overflow: hidden;
    font-size: {{ section.settings.wordmark_size }}vw;
    opacity: {{ section.settings.wordmark_opacity }};
    user-select: none;
  }

  /* Bottom bar */
  .altrd-footer__bottom {
    border-top: 1px solid var(--af-faint);
    padding-top: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .altrd-footer__legal { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .altrd-footer__legal span,
  .altrd-footer__legal a {
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 0.8125rem;
    color: var(--af-muted);
    text-decoration: none;
  }
  .altrd-footer__legal a:hover { color: var(--af-tx); }
  .altrd-footer__utils { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .altrd-footer__payment { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .altrd-footer__payment svg { width: 2.3rem; height: 1.5rem; }
  .altrd-footer__locale select {
    background: transparent;
    border: 1px solid var(--af-faint);
    color: var(--af-tx);
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
    font-size: 0.8125rem;
    padding: 0.4rem 0.6rem;
    border-radius: 0;
    cursor: pointer;
  }
  .altrd-footer__locale select option { color: #000; }

  @media screen and (max-width: 989px) {
    .altrd-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 2rem;
    }
    .altrd-footer__brandcol { grid-column: 1 / -1; }
  }
  @media screen and (max-width: 749px) {
    .altrd-footer__news-inner { flex-direction: column; align-items: stretch; gap: 1.5rem; }
    .altrd-footer__form { max-width: 100%; }
    .altrd-footer__bottom { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    .altrd-footer__wordmark { font-size: {{ section.settings.wordmark_size | times: 1.4 }}vw; }
  }
  @media screen and (max-width: 479px) {
    .altrd-footer__grid { grid-template-columns: 1fr 1fr; }
  }
{%- endstyle -%}

<footer class="altrd-footer">

  {%- if section.settings.show_newsletter -%}
    <div class="altrd-footer__news page-width">
      <div class="altrd-footer__news-inner">
        <div class="altrd-footer__news-text">
          {%- if section.settings.news_heading != blank -%}
            <h2 class="altrd-footer__news-heading">{{ section.settings.news_heading | escape }}</h2>
          {%- endif -%}
          {%- if section.settings.news_sub != blank -%}
            <p class="altrd-footer__news-sub">{{ section.settings.news_sub | escape }}</p>
          {%- endif -%}
        </div>
        <div class="altrd-footer__form">
          {%- form 'customer', class: 'altrd-footer__form-el' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="altrd-footer__form-row">
              <input
                type="email"
                name="contact[email]"
                class="altrd-footer__input"
                placeholder="{{ section.settings.news_placeholder | default: 'Enter your email' | escape }}"
                required
                aria-label="Email"
              >
              <button type="submit" class="altrd-footer__submit">{{ section.settings.news_button | default: 'Subscribe' | escape }}</button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="altrd-footer__form-note">{{ section.settings.news_success | default: 'Thanks for subscribing.' | escape }}</p>
            {%- elsif form.errors -%}
              <p class="altrd-footer__form-note">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="altrd-footer__grid page-width">

    <div class="altrd-footer__brandcol">
      {%- if section.settings.logo != blank -%}
        {%- assign logo_w = section.settings.logo_width -%}
        {{ section.settings.logo | image_url: width: 600 | image_tag: class: 'altrd-footer__logo-img', widths: '200, 400, 600', style: 'width: ' | append: logo_w | append: 'px;', alt: shop.name }}
      {%- elsif section.settings.logo_text != blank -%}
        <p class="altrd-footer__logo-text">{{ section.settings.logo_text | escape }}</p>
      {%- endif -%}

      {%- if section.settings.tagline != blank -%}
        <p class="altrd-footer__tagline">{{ section.settings.tagline | escape }}</p>
      {%- endif -%}

      {%- liquid
        assign has_social = false
        if section.settings.instagram_url != blank or section.settings.tiktok_url != blank or section.settings.youtube_url != blank or section.settings.twitter_url != blank or section.settings.facebook_url != blank
          assign has_social = true
        endif
      -%}
      {%- if has_social -%}
        <div class="altrd-footer__social">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="altrd-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" class="altrd-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 1 1 .79-5.68V9.01a6.34 6.34 0 1 0 5.55 6.3V8.75a8.18 8.18 0 0 0 4.78 1.52V6.82a4.85 4.85 0 0 1-1.02-.13z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.youtube_url != blank -%}
            <a href="{{ section.settings.youtube_url }}" class="altrd-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z" stroke="currentColor" stroke-width="1.8"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.twitter_url != blank -%}
            <a href="{{ section.settings.twitter_url }}" class="altrd-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="X">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="altrd-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'nav_column' -%}
        <div class="altrd-footer__col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h3 class="altrd-footer__col-heading">{{ block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul class="altrd-footer__nav-list" role="list">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}" class="altrd-footer__nav-link">{{ link.title | escape }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  {%- if section.settings.show_wordmark and section.settings.wordmark_text != blank -%}
    <p class="altrd-footer__wordmark" aria-hidden="true">{{ section.settings.wordmark_text | escape }}</p>
  {%- endif -%}

  <div class="altrd-footer__bottom page-width">
    <div class="altrd-footer__legal">
      {%- if section.settings.copyright != blank -%}
        <span>{{ section.settings.copyright | replace: '{year}', current_year | escape }}</span>
      {%- endif -%}
      {%- if section.settings.attribution != blank -%}
        <span>{{ section.settings.attribution | escape }}</span>
      {%- endif -%}
      {%- if section.settings.show_policy -%}
        {%- for policy in shop.policies -%}
          <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="altrd-footer__utils">
      {%- if section.settings.show_locale and localization.available_countries.size > 1 -%}
        <div class="altrd-footer__locale">
          {%- form 'localization', id: 'AltrdFooterLocale', class: 'altrd-footer__locale-form' -%}
            <select name="country_code" aria-label="Country/region" onchange="this.form.submit()">
              {%- for country in localization.available_countries -%}
                <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                  {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                </option>
              {%- endfor -%}
            </select>
            <input type="hidden" name="return_to" value="{{ request.path }}">
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_payment and shop.enabled_payment_types.size > 0 -%}
        <div class="altrd-footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'altrd-footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "ALTRD — Footer",
  "class": "altrd-footer-section",
  "tag": "div",
  "max_blocks": 5,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#0B0B0B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F4EFE6"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (headings + hover)",
      "default": "#E8FF52"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "news_heading",
      "label": "Heading",
      "default": "Join the movement"
    },
    {
      "type": "text",
      "id": "news_sub",
      "label": "Subtext",
      "default": "Drops, restocks and members-only offers — straight to your inbox."
    },
    {
      "type": "text",
      "id": "news_placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "news_button",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "news_success",
      "label": "Success message",
      "default": "You're in. Welcome to the club."
    },
    {
      "type": "header",
      "content": "Brand column"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image (optional)"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 280,
      "step": 5,
      "unit": "px",
      "label": "Logo width",
      "default": 130
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (if no image)",
      "default": "ALTRD"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Wear what you stand for."
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "X (Twitter)"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook"
    },
    {
      "type": "header",
      "content": "Giant wordmark"
    },
    {
      "type": "checkbox",
      "id": "show_wordmark",
      "label": "Show giant wordmark",
      "default": true
    },
    {
      "type": "text",
      "id": "wordmark_text",
      "label": "Wordmark text",
      "default": "ALTRD"
    },
    {
      "type": "range",
      "id": "wordmark_size",
      "min": 8,
      "max": 28,
      "step": 1,
      "unit": "vw",
      "label": "Wordmark size",
      "default": 20
    },
    {
      "type": "range",
      "id": "wordmark_opacity",
      "min": 0.1,
      "max": 1,
      "step": 0.05,
      "label": "Wordmark opacity",
      "default": 1
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright",
      "default": "© {year} ALTRD. All rights reserved.",
      "info": "Use {year} to auto-insert the current year."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution line (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "label": "Show store policy links",
      "default": true,
      "info": "Pulled from Settings → Policies."
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_locale",
      "label": "Show country / currency selector",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "nav_column",
      "name": "Navigation column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer",
          "info": "Create menus in Shopify Admin → Navigation."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALTRD — Footer",
      "blocks": [
        { "type": "nav_column", "settings": { "heading": "Shop", "menu": "main-menu" } },
        { "type": "nav_column", "settings": { "heading": "Help", "menu": "footer" } },
        { "type": "nav_column", "settings": { "heading": "Company", "menu": "footer" } }
      ]
    }
  ]
}
{% endschema %}
