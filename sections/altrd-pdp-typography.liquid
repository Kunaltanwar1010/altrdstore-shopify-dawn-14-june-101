{%- liquid
  assign s = section.settings
-%}
{%- style -%}
/* === ALTRD PDP — Typography & Spacing controls === */

/* Breadcrumbs */
product-info .altrd-breadcrumbs {
  font-size: {{ s.sz_breadcrumb }}px !important;
  margin-bottom: {{ s.sp_breadcrumb }}px !important;
}

/* Vendor / drop label */
product-info .product__text:not(.altrd-pdp-tagline) {
  font-size: {{ s.sz_vendor }}px !important;
}

/* Title */
product-info .product__title {
  font-size: {{ s.sz_title_desk }}px !important;
  margin-bottom: {{ s.sp_title }}px !important;
}
@media screen and (max-width: 749px) {
  product-info .product__title {
    font-size: {{ s.sz_title_mob }}px !important;
  }
}

/* Price */
product-info .altrd-pdp-price {
  margin-bottom: {{ s.sp_price }}px !important;
}
product-info .altrd-pdp-price__current {
  font-size: {{ s.sz_price }}px !important;
}
product-info .altrd-pdp-price__compare {
  font-size: {{ s.sz_price | times: 0.68 | round: 0 }}px !important;
}
product-info .altrd-pdp-price__save {
  font-size: {{ s.sz_save }}px !important;
}
product-info .product__tax {
  font-size: {{ s.sz_tax }}px !important;
}

/* Tagline */
product-info .altrd-pdp-tagline {
  font-size: {{ s.sz_tagline }}px !important;
  margin-bottom: {{ s.sp_tagline }}px !important;
}

/* Reviews badge */
product-info .altrd-reviews-badge {
  margin-bottom: {{ s.sp_reviews }}px !important;
}
product-info .altrd-reviews-badge__stars {
  font-size: {{ s.sz_reviews | plus: 2 }}px !important;
}
product-info .altrd-reviews-badge__text {
  font-size: {{ s.sz_reviews }}px !important;
}
product-info .altrd-reviews-badge__link {
  font-size: {{ s.sz_reviews | minus: 2 }}px !important;
}

/* Variant / size selector */
product-info variant-selects .form__label,
product-info .product-form__input > legend.form__label,
product-info fieldset.product-form__input legend {
  font-size: {{ s.sz_variant_label }}px !important;
}
product-info variant-selects,
product-info .product-form__input--pill,
product-info .product-form__input {
  margin-bottom: {{ s.sp_variant }}px !important;
}
product-info .product-form__input label,
product-info .product-form__input .product-form__label {
  font-size: {{ s.sz_variant_value }}px !important;
}

/* Collapsible tabs */
product-info .accordion__title.h4 {
  font-size: {{ s.sz_tab_heading }}px !important;
}
product-info .accordion__content {
  font-size: {{ s.sz_tab_content }}px !important;
}

/* Trust strip */
product-info .altrd-trust-strip__label {
  font-size: {{ s.sz_trust }}px !important;
}
{%- endstyle -%}

<div hidden></div>

