{%- liquid
  assign color_style = section.settings.color_style | default: 'bone'
  assign show_tag    = section.settings.show_product_tag
-%}

{%- style -%}
/* === ALTRD Testimonials === */
.altrd-testi {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
}
@media screen and (max-width: 749px) {
  .altrd-testi {
    padding: {{ section.settings.padding_top | times: 0.7 | round: 0 }}px 0 {{ section.settings.padding_bottom | times: 0.7 | round: 0 }}px;
  }
}
.altrd-testi--ink   { background: #0B0B0B; color: #F4EFE6; }
.altrd-testi--bone  { background: #F4EFE6; color: #0B0B0B; }
.altrd-testi--white { background: #FFFFFF; color: #0B0B0B; }

/* Header */
.altrd-testi__header {
  text-align: center;
  max-width: 40rem;
  margin: 0 auto 2.75rem;
}
@media screen and (max-width: 749px) {
  .altrd-testi__header { margin-bottom: 1.75rem; }
}
.altrd-testi__eyebrow {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin: 0 0 0.75rem;
  opacity: 0.45;
}
.altrd-testi--ink .altrd-testi__eyebrow { color: var(--color-altrd-hivis, #E8FF52); opacity: 1; }
.altrd-testi__heading {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(2rem, 4.5vw, 3.75rem);
  font-weight: 400;
  line-height: 0.95;
  text-transform: uppercase;
  margin: 0;
}

/* Grid */
.altrd-testi__grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: 1.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
}
@media screen and (min-width: 750px) and (max-width: 989px) {
  .altrd-testi__grid { grid-template-columns: repeat(2, 1fr); }
}

/* Mobile carousel */
@media screen and (max-width: 749px) {
  .altrd-testi__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 1rem;
    padding: 0 1.25rem 0.5rem;
    margin: 0 -1.5rem;
    cursor: grab;
  }
  .altrd-testi__grid::-webkit-scrollbar { display: none; }
  .altrd-testi__grid.altrd-testi__grid--dragging { cursor: grabbing; scroll-snap-type: none; }
  .altrd-testi__grid > li {
    flex: 0 0 82vw;
    max-width: 22rem;
    scroll-snap-align: start;
  }
}

/* Card */
.altrd-testi__card {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 1.75rem;
  border: 1px solid rgba(11,11,11,0.1);
  background: rgba(255,255,255,0.5);
}
.altrd-testi--ink .altrd-testi__card {
  border-color: rgba(244,239,230,0.14);
  background: rgba(255,255,255,0.03);
}
.altrd-testi--white .altrd-testi__card { background: #FAFAFA; }

.altrd-testi__stars {
  display: flex;
  gap: 0.125rem;
  color: var(--color-altrd-hivis, #E8FF52);
  font-size: 1rem;
  line-height: 1;
  margin-bottom: 1rem;
}
.altrd-testi--bone  .altrd-testi__stars,
.altrd-testi--white .altrd-testi__stars { color: #0B0B0B; }
.altrd-testi__star--empty { opacity: 0.22; }

.altrd-testi__quote {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1rem;
  line-height: 1.6;
  font-weight: 400;
  margin: 0 0 1.5rem;
  flex: 1 1 auto;
}
.altrd-testi__quote p { margin: 0 0 0.75rem; }
.altrd-testi__quote p:last-child { margin-bottom: 0; }

/* Author */
.altrd-testi__author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: auto;
}
.altrd-testi__avatar {
  width: 2.75rem;
  height: 2.75rem;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}
.altrd-testi__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-altrd-hivis, #E8FF52);
  color: #0B0B0B;
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: 1.25rem;
}
.altrd-testi__author-text { min-width: 0; }
.altrd-testi__name {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.875rem;
  font-weight: 700;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.375rem;
}
.altrd-testi__verified {
  display: inline-flex;
  align-items: center;
  gap: 0.2rem;
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  opacity: 0.55;
}
.altrd-testi__verified svg { width: 0.75rem; height: 0.75rem; }
.altrd-testi__meta {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.75rem;
  opacity: 0.5;
  margin: 0.1rem 0 0;
}

/* Tagged product chip */
.altrd-testi__product {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 1.25rem;
  padding-top: 1.25rem;
  border-top: 1px solid rgba(11,11,11,0.1);
  text-decoration: none;
  color: inherit;
  transition: opacity 0.15s ease;
}
.altrd-testi--ink .altrd-testi__product { border-top-color: rgba(244,239,230,0.14); }
.altrd-testi__product:hover { opacity: 0.7; }
.altrd-testi__product-media {
  width: 3rem;
  height: 3rem;
  flex-shrink: 0;
  overflow: hidden;
  background: rgba(11,11,11,0.06);
}
.altrd-testi__product-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
.altrd-testi__product-text { min-width: 0; }
.altrd-testi__product-label {
  display: block;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.625rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.45;
  margin-bottom: 0.15rem;
}
.altrd-testi__product-title {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.8125rem;
  font-weight: 600;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.altrd-testi__product-arrow { margin-left: auto; flex-shrink: 0; opacity: 0.4; }

/* Dots */
.altrd-testi__dots { display: none; align-items: center; justify-content: center; gap: 0.4375rem; margin-top: 1.25rem; }
@media screen and (max-width: 749px) { .altrd-testi__dots { display: flex; } }
.altrd-testi__dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: 0.25; transition: opacity 0.2s ease, transform 0.2s ease; }
.altrd-testi__dot--active { opacity: 1; transform: scale(1.4); }

.altrd-testi__empty {
  text-align: center;
  padding: 3rem 0;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  opacity: 0.45;
}
{%- endstyle -%}

<div class="altrd-testi altrd-testi--{{ color_style }}">
  <div class="page-width">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="altrd-testi__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="altrd-testi__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="altrd-testi__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="altrd-testi__grid" id="AltrdTestiTrack-{{ section.id }}" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign tagged = block.settings.product
            assign rating = block.settings.rating | default: 5
          -%}
          <li {{ block.shopify_attributes }}>
            <div class="altrd-testi__card">
              <div class="altrd-testi__stars" aria-label="{{ rating }} out of 5 stars">
                {%- for i in (1..5) -%}
                  {%- if i <= rating -%}
                    <span class="altrd-testi__star" aria-hidden="true">★</span>
                  {%- else -%}
                    <span class="altrd-testi__star altrd-testi__star--empty" aria-hidden="true">★</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <div class="altrd-testi__quote">{{ block.settings.quote }}</div>

              <div class="altrd-testi__author">
                {%- if block.settings.author_image != blank -%}
                  {{ block.settings.author_image | image_url: width: 120 | image_tag: class: 'altrd-testi__avatar', loading: 'lazy', alt: block.settings.author_name | escape }}
                {%- elsif block.settings.author_name != blank -%}
                  <span class="altrd-testi__avatar altrd-testi__avatar--placeholder" aria-hidden="true">{{ block.settings.author_name | strip | slice: 0 | upcase }}</span>
                {%- endif -%}
                <div class="altrd-testi__author-text">
                  {%- if block.settings.author_name != blank -%}
                    <p class="altrd-testi__name">
                      {{ block.settings.author_name | escape }}
                      {%- if block.settings.verified -%}
                        <span class="altrd-testi__verified">
                          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/></svg>
                          Verified
                        </span>
                      {%- endif -%}
                    </p>
                  {%- endif -%}
                  {%- if block.settings.author_meta != blank -%}
                    <p class="altrd-testi__meta">{{ block.settings.author_meta | escape }}</p>
                  {%- endif -%}
                </div>
              </div>

              {%- if tagged != blank and show_tag -%}
                <a href="{{ tagged.url }}" class="altrd-testi__product" aria-label="{{ tagged.title | escape }}">
                  <span class="altrd-testi__product-media">
                    {%- if tagged.featured_image != blank -%}
                      {{ tagged.featured_image | image_url: width: 120 | image_tag: loading: 'lazy', alt: tagged.title | escape }}
                    {%- endif -%}
                  </span>
                  <span class="altrd-testi__product-text">
                    <span class="altrd-testi__product-label">Reviewed product</span>
                    <span class="altrd-testi__product-title">{{ tagged.title | escape }}</span>
                  </span>
                  <svg class="altrd-testi__product-arrow" width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M3 9h12M10 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.blocks.size > 1 -%}
        <div class="altrd-testi__dots" id="AltrdTestiDots-{{ section.id }}" aria-hidden="true">
          {%- for block in section.blocks -%}
            <span class="altrd-testi__dot{% if forloop.first %} altrd-testi__dot--active{% endif %}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <script>
        (function () {
          var track = document.getElementById('AltrdTestiTrack-{{ section.id }}');
          var dotsWrap = document.getElementById('AltrdTestiDots-{{ section.id }}');
          if (!track) return;
          var dots = dotsWrap ? Array.prototype.slice.call(dotsWrap.querySelectorAll('.altrd-testi__dot')) : [];

          function updateDots() {
            if (!dots.length) return;
            var cards = track.querySelectorAll('li');
            var trackLeft = track.getBoundingClientRect().left;
            var closest = 0, closestDist = Infinity;
            cards.forEach(function (card, i) {
              var dist = Math.abs(card.getBoundingClientRect().left - trackLeft);
              if (dist < closestDist) { closestDist = dist; closest = i; }
            });
            dots.forEach(function (dot, i) { dot.classList.toggle('altrd-testi__dot--active', i === closest); });
          }

          var ticking = false;
          track.addEventListener('scroll', function () {
            if (ticking) return;
            ticking = true;
            window.requestAnimationFrame(function () { updateDots(); ticking = false; });
          }, { passive: true });

          var isDown = false, startX = 0, startScroll = 0;
          track.addEventListener('pointerdown', function (e) {
            if (e.pointerType === 'mouse' && e.button !== 0) return;
            isDown = true; track.classList.add('altrd-testi__grid--dragging');
            startX = e.clientX; startScroll = track.scrollLeft;
            track.setPointerCapture(e.pointerId);
          });
          track.addEventListener('pointermove', function (e) {
            if (!isDown) return;
            track.scrollLeft = startScroll - (e.clientX - startX);
          });
          function endDrag() {
            if (!isDown) return;
            isDown = false; track.classList.remove('altrd-testi__grid--dragging'); updateDots();
          }
          track.addEventListener('pointerup', endDrag);
          track.addEventListener('pointercancel', endDrag);
          track.addEventListener('pointerleave', endDrag);
        })();
      </script>

    {%- elsif request.design_mode -%}
      <p class="altrd-testi__empty">Add testimonial blocks in the section settings.</p>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "ALTRD — Testimonials",
  "tag": "section",
  "class": "altrd-testimonials-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Real reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What the squad says"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on desktop",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_product_tag",
      "label": "Show tagged product on cards",
      "default": true
    },
    {
      "type": "select",
      "id": "color_style",
      "label": "Background",
      "default": "bone",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "bone",  "label": "Bone (light)" },
        { "value": "ink",   "label": "Ink (dark)" }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote",
          "default": "<p>Best fit I've owned. The fabric is heavy in the best way and it hasn't faded after a dozen washes.</p>"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Aarav M."
        },
        {
          "type": "text",
          "id": "author_meta",
          "label": "Author detail (location / handle)",
          "default": "Mumbai · Verified buyer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo (optional)"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        },
        {
          "type": "header",
          "content": "Tag a product"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Reviewed product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ALTRD — Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial", "settings": { "author_name": "Diya K.", "author_meta": "Delhi · Verified buyer", "quote": "<p>Oversized but structured — exactly what the photos showed. Shipping was quick too.</p>" } },
        { "type": "testimonial", "settings": { "author_name": "Kabir S.", "author_meta": "Bengaluru · Verified buyer", "quote": "<p>The print quality is unreal. Gets compliments every single time I wear it.</p>" } }
      ]
    }
  ]
}
{% endschema %}
