      "name": "ALTRD — UGC Strip",
      "settings": {
        "eyebrow": "Real ones",
        "heading": "Worn in the wild.",
        "cta_label": "Follow @cs.ujjawalpahwa",
        "color_style": "ink"
      },
      "blocks": [
        { "type": "post", "settings": { "handle": "@username", "caption": "This is more than merch." } },
        { "type": "post", "settings": { "handle": "@username", "caption": "The mindset is real." } },
        { "type": "post", "settings": { "handle": "@username", "caption": "Wearing the idea daily." } },
        { "type": "post", "settings": { "handle": "@username", "caption": "Drop 001 already hits different." } },
        { "type": "post", "settings": { "handle": "@username", "caption": "Compound is the one." } }
      ]
    }
  ]
}
