<div class="altrd-ugc altrd-ugc--{{ section.settings.color_style }}">

  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="altrd-ugc__header page-width">
      {%- if section.settings.eyebrow != blank -%}
        <p class="altrd-ugc__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="altrd-ugc__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div
      class="altrd-ugc__grid"
      style="--ugc-cols: {{ section.blocks.size | at_most: 6 }};"
    >
      {%- for block in section.blocks -%}
        {%- assign ph_i = forloop.index | modulo: 2 | plus: 1 -%}
        <div class="altrd-ugc__cell" {{ block.shopify_attributes }}>

          {%- if block.settings.link != blank -%}
            <a
              href="{{ block.settings.link }}"
              class="altrd-ugc__post"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ block.settings.handle | default: 'View on Instagram' | escape }}"
            >
          {%- else -%}
            <div class="altrd-ugc__post">
          {%- endif -%}

            <div class="altrd-ugc__img-wrap">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'altrd-ugc__img',
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 17vw, (min-width: 550px) 34vw, 72vw',
                    widths: '300, 500, 700, 900'
                }}
              {%- else -%}
                {{ 'lifestyle-' | append: ph_i | placeholder_svg_tag: 'altrd-ugc__placeholder' }}
              {%- endif -%}

              {%- if block.settings.handle != blank or block.settings.caption != blank -%}
                <div class="altrd-ugc__overlay" aria-hidden="true">
                  {%- if block.settings.handle != blank -%}
                    <span class="altrd-ugc__overlay-handle">{{ block.settings.handle | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.caption != blank -%}
                    <p class="altrd-ugc__overlay-caption">{{ block.settings.caption | escape }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.cta_label != blank -%}
    <div class="altrd-ugc__footer page-width">
      <a
        href="{{ section.settings.cta_link | default: '#' }}"
        class="altrd-ugc__cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="altrd-ugc__ig-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
        <span>{{ section.settings.cta_label | escape }}</span>
        <svg class="altrd-ugc__arrow" width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  {%- endif -%}

</div>

{% stylesheet %}
/* === ALTRD custom === */

.altrd-ugc {
  overflow: hidden;
}

.altrd-ugc--ink  { background: var(--color-altrd-ink, #0B0B0B);  color: var(--color-altrd-bone, #F4EFE6); }
.altrd-ugc--bone { background: var(--color-altrd-bone, #F4EFE6); color: var(--color-altrd-ink, #0B0B0B); }

.altrd-ugc__header {
  padding: 7rem 0 4.5rem;
}

@media screen and (max-width: 749px) {
  .altrd-ugc__header { padding: 5rem 0 3.5rem; }
}

.altrd-ugc__eyebrow {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-altrd-hivis, #E8FF52);
  margin: 0 0 1.5rem;
}

.altrd-ugc--bone .altrd-ugc__eyebrow {
  color: var(--color-altrd-ink, #0B0B0B);
  opacity: 0.4;
}

.altrd-ugc__heading {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(3rem, 6vw, 7.5rem);
  font-weight: 400;
  line-height: 0.92;
  text-transform: uppercase;
  margin: 0;
  word-break: break-word;
}

/* === Grid === */

.altrd-ugc__grid {
  display: grid;
  grid-template-columns: repeat(var(--ugc-cols, 5), 1fr);
  gap: 2px;
}

@media screen and (min-width: 550px) and (max-width: 989px) {
  .altrd-ugc__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media screen and (max-width: 549px) {
  .altrd-ugc__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 2px;
  }
  .altrd-ugc__grid::-webkit-scrollbar { display: none; }
  .altrd-ugc__cell {
    flex: 0 0 72vw;
    scroll-snap-align: start;
  }
}

/* === Cell & Post === */

.altrd-ugc__post {
  display: block;
  text-decoration: none;
  color: inherit;
}

.altrd-ugc__img-wrap {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
}

.altrd-ugc__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

a.altrd-ugc__post:hover .altrd-ugc__img {
  transform: scale(1.05);
}

@media (prefers-reduced-motion: reduce) {
  .altrd-ugc__img { transition: none; }
}

.altrd-ugc__placeholder {
  width: 100%;
  height: 100%;
  display: block;
}

.altrd-ugc--ink  .altrd-ugc__placeholder { color: rgba(244, 239, 230, 0.05); }
.altrd-ugc--bone .altrd-ugc__placeholder { color: rgba(11, 11, 11, 0.05); }

/* === Overlay === */

.altrd-ugc__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(11, 11, 11, 0.88) 0%, rgba(11, 11, 11, 0.3) 45%, transparent 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1.125rem;
  opacity: 0;
  transition: opacity 0.25s ease;
}

a.altrd-ugc__post:hover .altrd-ugc__overlay {
  opacity: 1;
}

@media (hover: none) {
  .altrd-ugc__overlay {
    opacity: 1;
    background: linear-gradient(to top, rgba(11, 11, 11, 0.72) 0%, transparent 55%);
  }
}

.altrd-ugc__overlay-handle {
  display: block;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--color-altrd-hivis, #E8FF52);
  margin-bottom: 0.25rem;
}

.altrd-ugc__overlay-caption {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.75rem;
  font-weight: 400;
  line-height: 1.45;
  color: rgba(244, 239, 230, 0.82);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* === Footer CTA === */

.altrd-ugc__footer {
  padding: 4rem 0 6.5rem;
}

@media screen and (max-width: 749px) {
  .altrd-ugc__footer { padding: 3rem 0 5rem; }
}

.altrd-ugc__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  color: inherit;
  padding-bottom: 3px;
  border-bottom: 1.5px solid currentColor;
  transition: gap 0.2s ease;
}

.altrd-ugc__cta:hover { gap: 1rem; }

.altrd-ugc__ig-icon { flex-shrink: 0; }

.altrd-ugc__arrow {
  flex-shrink: 0;
  transition: transform 0.2s ease;
}

.altrd-ugc__cta:hover .altrd-ugc__arrow {
  transform: translateX(4px);
}
{% endstylesheet %}

{% schema %}
{
  "name": "ALTRD — UGC Strip",
  "class": "altrd-ugc-section",
  "tag": "div",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Real ones"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Worn in the wild."
    },
    {
      "type": "header",
      "content": "Instagram link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Follow @cs.ujjawalpahwa"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "info": "Link to the Instagram profile or hashtag page."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_style",
      "label": "Color style",
      "options": [
        { "value": "ink",  "label": "Ink (dark)" },
        { "value": "bone", "label": "Bone (light)" }
      ],
      "default": "ink"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "UGC Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo",
          "info": "Square images work best (1:1 ratio)."
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Instagram handle",
          "placeholder": "@username"
        },
        {
          "type": "text",
          "id": "caption",
