{%- liquid
  assign the_collection = section.settings.collection
  assign has_collection = false
  if the_collection != blank
    assign has_collection = true
  endif
  assign section_heading = section.settings.heading
  if section_heading == blank and has_collection
    assign section_heading = the_collection.title
  endif
-%}

<section class="altrd-drop altrd-drop--{{ section.settings.color_style }}">

  <div class="altrd-drop__header page-width">
    <div class="altrd-drop__header-left">
      {%- if section.settings.drop_label != blank -%}
        <p class="altrd-drop__eyebrow">{{ section.settings.drop_label | escape }}</p>
      {%- endif -%}
      {%- if section_heading != blank -%}
        <h2 class="altrd-drop__title">{{ section_heading | escape }}</h2>
      {%- endif -%}
    </div>
    <div class="altrd-drop__header-right">
      {%- if section.settings.tagline != blank -%}
        <p class="altrd-drop__tagline">{{ section.settings.tagline | escape }}</p>
      {%- endif -%}
      {%- if section.settings.show_view_all and has_collection -%}
        <a href="{{ the_collection.url }}" class="altrd-drop__view-all">
          <span>{{ section.settings.view_all_label | default: 'View all' | escape }}</span>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3 9h12M10 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="altrd-drop__grid page-width">
    {%- if has_collection and the_collection.products.size > 0 -%}
      {%- for product in the_collection.products limit: section.settings.products_to_show -%}
        {%- liquid
          assign is_featured = false
          if forloop.first and section.settings.first_product_featured
            assign is_featured = true
          endif
          assign is_on_sale = false
          if product.compare_at_price > product.price
            assign is_on_sale = true
          endif
        -%}
        <a
          href="{{ product.url }}"
          class="altrd-drop__card{% if is_featured %} altrd-drop__card--featured{% endif %}{% unless product.available %} altrd-drop__card--sold-out{% endunless %}"
          aria-label="{{ product.title | escape }}"
        >
          <div class="altrd-drop__card-media">
            {%- if product.featured_image != blank -%}
              {{
                product.featured_image
                | image_url: width: 1200
                | image_tag:
                  class: 'altrd-drop__card-img',
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 33vw, 50vw',
                  widths: '375, 550, 750, 900, 1200',
                  alt: product.featured_image.alt | escape
              }}
            {%- else -%}
              {{ 'product-apparel-1' | placeholder_svg_tag: 'altrd-drop__card-placeholder' }}
            {%- endif -%}

            <div class="altrd-drop__card-badges">
              {%- if is_featured and section.settings.drop_label != blank -%}
                <span class="altrd-drop__badge altrd-drop__badge--drop">{{ section.settings.drop_label | escape }}</span>
              {%- endif -%}
              {%- unless product.available -%}
                <span class="altrd-drop__badge altrd-drop__badge--sold-out">Sold out</span>
              {%- endunless -%}
              {%- if is_on_sale and product.available -%}
                <span class="altrd-drop__badge altrd-drop__badge--sale">Sale</span>
              {%- endif -%}
            </div>

            <div class="altrd-drop__card-hover" aria-hidden="true">
              <span class="altrd-drop__card-shop">Shop now</span>
            </div>
          </div>

          <div class="altrd-drop__card-info">
            <p class="altrd-drop__card-name">{{ product.title | escape }}</p>
            <div class="altrd-drop__card-pricing">
              <span class="altrd-drop__card-price{% if is_on_sale %} altrd-drop__card-price--sale{% endif %}">
                {{- product.price | money -}}
              </span>
              {%- if is_on_sale -%}
                <s class="altrd-drop__card-compare">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..section.settings.products_to_show) -%}
        <div class="altrd-drop__card{% if forloop.first and section.settings.first_product_featured %} altrd-drop__card--featured{% endif %}">
          <div class="altrd-drop__card-media">
            {{ 'product-apparel-1' | placeholder_svg_tag: 'altrd-drop__card-placeholder' }}
          </div>
          <div class="altrd-drop__card-info">
            <p class="altrd-drop__card-name">Product title</p>
            <p class="altrd-drop__card-price">{{ 1999 | money }}</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if section.settings.show_view_all and has_collection -%}
    <div class="altrd-drop__footer page-width">
      <a href="{{ the_collection.url }}" class="altrd-drop__footer-link">
        {{ section.settings.view_all_label | default: 'View the full drop' | escape }}
      </a>
    </div>
  {%- endif -%}

</section>

{% stylesheet %}
/* === ALTRD custom === */

.altrd-drop {
  padding: 6rem 0;
}

.altrd-drop--ink  { background: var(--color-altrd-ink, #0B0B0B); color: var(--color-altrd-bone, #F4EFE6); }
.altrd-drop--bone { background: var(--color-altrd-bone, #F4EFE6); color: var(--color-altrd-ink, #0B0B0B); }

@media screen and (max-width: 749px) {
  .altrd-drop { padding: 4rem 0; }
}

.altrd-drop__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  margin-bottom: 3rem;
}

@media screen and (max-width: 749px) {
  .altrd-drop__header {
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
}

.altrd-drop__eyebrow {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-altrd-hivis, #E8FF52);
  margin: 0 0 0.75rem;
}

.altrd-drop--bone .altrd-drop__eyebrow {
  color: var(--color-altrd-ink, #0B0B0B);
  opacity: 0.45;
}

.altrd-drop__title {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(2.5rem, 5vw, 5rem);
  font-weight: 400;
  line-height: 0.95;
  text-transform: uppercase;
  margin: 0;
}

.altrd-drop__header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 1rem;
  flex-shrink: 0;
  max-width: 36ch;
  text-align: right;
}

@media screen and (max-width: 749px) {
  .altrd-drop__header-right {
    align-items: flex-start;
    text-align: left;
  }
}

.altrd-drop__tagline {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.9375rem;
  font-weight: 400;
  line-height: 1.6;
  opacity: 0.65;
  margin: 0;
}

.altrd-drop__view-all {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  color: inherit;
  padding-bottom: 2px;
  border-bottom: 1.5px solid currentColor;
  transition: gap 0.2s ease;
}

.altrd-drop__view-all:hover { gap: 0.875rem; }

.altrd-drop__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

@media screen and (min-width: 750px) and (max-width: 989px) {
  .altrd-drop__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 749px) {
  .altrd-drop__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }
}

.altrd-drop__card--featured {
  grid-column: span 2;
}

@media screen and (max-width: 749px) {
  .altrd-drop__card--featured {
    grid-column: span 2;
  }
}

.altrd-drop__card {
  display: block;
  text-decoration: none;
  color: inherit;
}

.altrd-drop__card-media {
  position: relative;
  overflow: hidden;
  background: #111;
  aspect-ratio: 3 / 4;
}

.altrd-drop__card--featured .altrd-drop__card-media {
  aspect-ratio: 4 / 3;
}

@media screen and (max-width: 749px) {
  .altrd-drop__card--featured .altrd-drop__card-media,
  .altrd-drop__card-media {
    aspect-ratio: 3 / 4;
  }
}

.altrd-drop__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.altrd-drop__card:hover .altrd-drop__card-img {
  transform: scale(1.04);
}

.altrd-drop__card-placeholder {
  width: 100%;
  height: 100%;
  opacity: 0.15;
}

.altrd-drop__card-badges {
  position: absolute;
  top: 1rem;
  left: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  z-index: 1;
}

.altrd-drop__badge {
  display: inline-block;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.625rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.3rem 0.6rem;
}

.altrd-drop__badge--drop {
  background: var(--color-altrd-hivis, #E8FF52);
  color: var(--color-altrd-ink, #0B0B0B);
}

.altrd-drop__badge--sold-out {
  background: rgba(11, 11, 11, 0.75);
  color: var(--color-altrd-bone, #F4EFE6);
}

.altrd-drop__badge--sale {
  background: var(--color-altrd-ink, #0B0B0B);
  color: var(--color-altrd-hivis, #E8FF52);
}

.altrd-drop__card-hover {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 1.5rem;
  background: linear-gradient(to top, rgba(11,11,11,0.55) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.25s ease;
}

.altrd-drop__card:hover .altrd-drop__card-hover {
  opacity: 1;
}

@media (hover: none) {
  .altrd-drop__card-hover { display: none; }
}

.altrd-drop__card-shop {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-altrd-bone, #F4EFE6);
  background: var(--color-altrd-ink, #0B0B0B);
  padding: 0.625rem 1.5rem;
}

.altrd-drop__card--sold-out .altrd-drop__card-img {
  opacity: 0.45;
}

.altrd-drop__card-info {
  padding: 0.875rem 0 0;
}

.altrd-drop__card-name {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.9375rem;
  font-weight: 500;
  letter-spacing: 0.01em;
  margin: 0 0 0.3rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.altrd-drop__card-pricing {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
}

.altrd-drop__card-price {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.9375rem;
  font-weight: 600;
}

.altrd-drop__card-price--sale { color: var(--color-altrd-hivis, #E8FF52); }
.altrd-drop--bone .altrd-drop__card-price--sale { color: #b00; }

.altrd-drop__card-compare {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.8125rem;
  opacity: 0.45;
  text-decoration: line-through;
}

.altrd-drop__footer {
  margin-top: 3rem;
  text-align: center;
}

.altrd-drop__footer-link {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  color: inherit;
  padding: 1rem 2.5rem;
  border: 1.5px solid currentColor;
  transition: background 0.18s ease, color 0.18s ease;
}

.altrd-drop--ink .altrd-drop__footer-link:hover {
  background: var(--color-altrd-bone, #F4EFE6);
  color: var(--color-altrd-ink, #0B0B0B);
  border-color: var(--color-altrd-bone, #F4EFE6);
}

.altrd-drop--bone .altrd-drop__footer-link:hover {
  background: var(--color-altrd-ink, #0B0B0B);
  color: var(--color-altrd-bone, #F4EFE6);
  border-color: var(--color-altrd-ink, #0B0B0B);
}
{% endstylesheet %}

{% schema %}
{
  "name": "ALTRD — Featured drop",
  "class": "altrd-drop-section",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Drop details"
    },
    {
      "type": "text",
      "id": "drop_label",
      "label": "Drop label",
      "default": "Drop 001",
      "info": "Shown as eyebrow text and as a badge on the featured product."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Defaults to collection title if left blank."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "One idea. Worn differently."
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "first_product_featured",
      "label": "Feature first product (larger card)",
      "default": true
    },
    {
      "type": "header",
      "content": "View all"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' links",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View the full drop"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_style",
      "label": "Color style",
      "options": [
        { "value": "ink",  "label": "Ink (dark)" },
        { "value": "bone", "label": "Bone (light)" }
      ],
      "default": "ink"
    }
  ],
  "presets": [
    {
      "name": "ALTRD — Featured drop",
      "settings": {
        "drop_label": "Drop 001",
        "tagline": "One idea. Worn differently.",
        "products_to_show": 5,
        "first_product_featured": true,
        "show_view_all": true,
        "view_all_label": "View the full drop",
        "color_style": "ink"
      }
    }
  ]
}
{% endschema %}
