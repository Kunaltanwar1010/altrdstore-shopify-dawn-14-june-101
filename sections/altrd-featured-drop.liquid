{%- liquid
  assign the_collection = section.settings.collection
  assign has_collection = false
  if the_collection != blank
    assign has_collection = true
  endif
  assign section_heading = section.settings.heading
  if section_heading == blank and has_collection
    assign section_heading = the_collection.title
  endif
-%}

<section class="altrd-drop altrd-drop--{{ section.settings.color_style }}">

  <div class="altrd-drop__header page-width">
    {%- if section.settings.drop_label != blank -%}
      <p class="altrd-drop__eyebrow">{{ section.settings.drop_label | escape }}</p>
    {%- endif -%}

    <div class="altrd-drop__header-row">
      {%- if section_heading != blank -%}
        <h2 class="altrd-drop__title">{{ section_heading | escape }}</h2>
      {%- endif -%}

      <div class="altrd-drop__header-actions">
        <div class="altrd-drop__arrows">
          <button type="button" class="altrd-drop__arrow" id="AltrdDropPrev-{{ section.id }}" aria-label="Previous">
            <svg viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 4l-5 5 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button type="button" class="altrd-drop__arrow" id="AltrdDropNext-{{ section.id }}" aria-label="Next">
            <svg viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
        {%- if section.settings.show_view_all and has_collection -%}
          <a href="{{ the_collection.url }}" class="altrd-drop__view-all altrd-drop__view-all--desktop">
            <span>{{ section.settings.view_all_label | default: 'View all' | escape }}</span>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3 9h12M10 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.tagline != blank -%}
      <p class="altrd-drop__tagline">{{ section.settings.tagline | escape }}</p>
    {%- endif -%}
  </div>

  <div class="altrd-drop__grid page-width" id="AltrdDropTrack-{{ section.id }}">
    {%- if has_collection and the_collection.products.size > 0 -%}
      {%- for product in the_collection.products limit: section.settings.products_to_show -%}
        {%- liquid
          assign is_on_sale = false
          if product.compare_at_price > product.price
            assign is_on_sale = true
          endif
        -%}
        <a
          href="{{ product.url }}"
          class="altrd-drop__card{% unless product.available %} altrd-drop__card--sold-out{% endunless %}"
          aria-label="{{ product.title | escape }}"
        >
          <div class="altrd-drop__card-media">
            {%- if product.featured_image != blank -%}
              {{
                product.featured_image
                | image_url: width: 900
                | image_tag:
                  class: 'altrd-drop__card-img',
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 25vw, 50vw',
                  widths: '375, 550, 750, 900',
                  alt: product.featured_image.alt | escape
              }}
              {%- if product.images.size > 1 -%}
                {{
                  product.images[1]
                  | image_url: width: 900
                  | image_tag:
                    class: 'altrd-drop__card-img altrd-drop__card-img--alt',
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 25vw, 50vw',
                    widths: '375, 550, 750, 900',
                    alt: product.images[1].alt | escape
                }}
              {%- endif -%}
            {%- else -%}
              {{ 'product-apparel-1' | placeholder_svg_tag: 'altrd-drop__card-placeholder' }}
            {%- endif -%}

            <div class="altrd-drop__card-badges">
              {%- unless product.available -%}
                <span class="altrd-drop__badge altrd-drop__badge--sold-out">Sold out</span>
              {%- endunless -%}
              {%- if is_on_sale and product.available -%}
                <span class="altrd-drop__badge altrd-drop__badge--sale">Sale</span>
              {%- endif -%}
            </div>

            <div class="altrd-drop__card-hover" aria-hidden="true">
              <span class="altrd-drop__card-shop">Shop now</span>
            </div>
          </div>

          <div class="altrd-drop__card-info">
            <p class="altrd-drop__card-name">{{ product.title | escape }}</p>
            <div class="altrd-drop__card-pricing">
              <span class="altrd-drop__card-price{% if is_on_sale %} altrd-drop__card-price--sale{% endif %}">
                {{- product.price | money -}}
              </span>
              {%- if is_on_sale -%}
                <s class="altrd-drop__card-compare">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..section.settings.products_to_show) -%}
        <div class="altrd-drop__card">
          <div class="altrd-drop__card-media">
            {{ 'product-apparel-1' | placeholder_svg_tag: 'altrd-drop__card-placeholder' }}
          </div>
          <div class="altrd-drop__card-info">
            <p class="altrd-drop__card-name">Product title</p>
            <p class="altrd-drop__card-price">{{ 1999 | money }}</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if section.settings.show_view_all and has_collection -%}
    <div class="altrd-drop__footer page-width">
      <a href="{{ the_collection.url }}" class="altrd-drop__footer-link">
        {{ section.settings.view_all_label | default: 'View all' | escape }}
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 9h12M10 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  {%- endif -%}

</section>

{% stylesheet %}
/* === ALTRD custom === */

.altrd-drop {
  padding: 5rem 0;
}

.altrd-drop--ink  { background: var(--color-altrd-ink, #000000);  color: var(--color-altrd-bone, #FFFFFF); }
.altrd-drop--bone { background: var(--color-altrd-bone, #FFFFFF); color: var(--color-altrd-ink, #000000); }

@media screen and (max-width: 749px) {
  .altrd-drop { padding: 3.5rem 0; }
}

.altrd-drop__header {
  margin-bottom: 3rem;
}

@media screen and (max-width: 749px) {
  .altrd-drop__header { margin-bottom: 2.5rem; }
}

.altrd-drop__eyebrow {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-altrd-hivis, #FFFFFF);
  margin: 0 0 0.875rem;
}

.altrd-drop--bone .altrd-drop__eyebrow {
  color: var(--color-altrd-ink, #000000);
  opacity: 0.4;
}

.altrd-drop__header-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  margin-bottom: 1.25rem;
}
.altrd-drop__header-actions {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-shrink: 0;
}

.altrd-drop__title {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(2.75rem, 5.5vw, 5.5rem);
  font-weight: 400;
  line-height: 0.93;
  text-transform: uppercase;
  margin: 0;
}

.altrd-drop__tagline {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1.1875rem;
  font-weight: 400;
  line-height: 1.6;
  margin: 0 0 0.75rem;
  max-width: 60ch;
  opacity: 0.7;
}

.altrd-drop__view-all--desktop {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  color: inherit;
  white-space: nowrap;
  flex-shrink: 0;
  padding-bottom: 2px;
  border-bottom: 1.5px solid currentColor;
  transition: gap 0.2s ease;
}

.altrd-drop__view-all--desktop:hover { gap: 0.875rem; }

@media screen and (max-width: 749px) {
  .altrd-drop__view-all--desktop { display: none; }
}

/* Horizontal carousel (desktop + mobile) */
.altrd-drop__grid {
  display: flex;
  gap: 1.5rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  cursor: grab;
  padding-bottom: 0.5rem;
}
.altrd-drop__grid::-webkit-scrollbar { display: none; }
.altrd-drop__grid.is-dragging { cursor: grabbing; scroll-snap-type: none; scroll-behavior: auto; }
.altrd-drop__grid > .altrd-drop__card {
  flex: 0 0 calc((100% - 3 * 1.5rem) / 4);
  scroll-snap-align: start;
}
.altrd-drop__grid.is-dragging > .altrd-drop__card { pointer-events: none; }

@media screen and (min-width: 750px) and (max-width: 989px) {
  .altrd-drop__grid > .altrd-drop__card { flex-basis: calc((100% - 2 * 1.5rem) / 3); }
}
@media screen and (max-width: 749px) {
  .altrd-drop__grid { gap: 1rem; }
  .altrd-drop__grid > .altrd-drop__card { flex: 0 0 72vw; max-width: 18rem; }
}

/* Carousel arrows */
.altrd-drop__arrows {
  display: none;
  gap: 0.5rem;
}
@media screen and (min-width: 750px) {
  .altrd-drop__arrows { display: inline-flex; }
}
.altrd-drop__arrow {
  width: 2.75rem;
  height: 2.75rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid currentColor;
  background: transparent;
  color: inherit;
  border-radius: 50%;
  cursor: pointer;
  transition: background 0.18s ease, color 0.18s ease, opacity 0.18s ease;
}
.altrd-drop__arrow:hover { background: currentColor; }
.altrd-drop__arrow:hover svg { color: var(--altrd-drop-arrow-hover, #000); }
.altrd-drop__arrow svg { width: 1.1rem; height: 1.1rem; }
.altrd-drop__arrow[disabled] { opacity: 0.25; pointer-events: none; }

.altrd-drop__card {
  display: block;
  text-decoration: none;
  color: inherit;
}

.altrd-drop__card-media {
  position: relative;
  overflow: hidden;
  background: #111111;
  aspect-ratio: 3 / 4;
}

.altrd-drop--bone .altrd-drop__card-media { background: #F2F2F2; }

.altrd-drop__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.altrd-drop__card:hover .altrd-drop__card-img { transform: scale(1.05); }

/* Hover: reveal second product image */
.altrd-drop__card-img--alt {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.5s ease, transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  z-index: 1;
}
.altrd-drop__card:hover .altrd-drop__card-img--alt {
  opacity: 1;
}

.altrd-drop__card-placeholder {
  width: 100%;
  height: 100%;
  opacity: 0.12;
}

.altrd-drop__card--sold-out .altrd-drop__card-img { opacity: 0.45; }

.altrd-drop__card-badges {
  position: absolute;
  top: 0.875rem;
  left: 0.875rem;
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  z-index: 2;
}

.altrd-drop__badge {
  display: inline-block;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.375rem 0.75rem;
}

.altrd-drop__badge--sold-out {
  background: rgba(0, 0, 0, 0.7);
  color: #FFFFFF;
}

.altrd-drop__badge--sale {
  background: var(--color-altrd-hivis, #FFFFFF);
  color: var(--color-altrd-ink, #000000);
}

.altrd-drop__card-hover {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 1.25rem;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 55%);
  opacity: 0;
  transition: opacity 0.22s ease;
  z-index: 3;
}

.altrd-drop__card:hover .altrd-drop__card-hover { opacity: 1; }

@media (hover: none) { .altrd-drop__card-hover { display: none; } }

.altrd-drop__card-shop {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-altrd-ink, #000000);
  background: var(--color-altrd-bone, #FFFFFF);
  padding: 0.5rem 1.25rem;
}

.altrd-drop__card-info {
  padding: 1.25rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.altrd-drop__card-name {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1.0625rem;
  font-weight: 500;
  line-height: 1.35;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.altrd-drop__card-pricing {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.altrd-drop__card-price {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1.125rem;
  font-weight: 700;
}

.altrd-drop--ink  .altrd-drop__card-price--sale { color: var(--color-altrd-hivis, #FFFFFF); }
.altrd-drop--bone .altrd-drop__card-price--sale { color: #b33; }

.altrd-drop__card-compare {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1.0625rem;
  font-weight: 400;
  opacity: 0.38;
  text-decoration: line-through;
}

.altrd-drop__footer {
  margin-top: 4rem;
  text-align: center;
}

.altrd-drop__footer a {
  margin-top: 20px;
}

.altrd-drop__footer-link {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  color: inherit;
  padding: 1rem 2.75rem;
  border: 1.5px solid currentColor;
  transition: background 0.18s ease, color 0.18s ease;
}

.altrd-drop--ink .altrd-drop__footer-link:hover {
  background: var(--color-altrd-bone, #FFFFFF);
  color: var(--color-altrd-ink, #000000);
  border-color: var(--color-altrd-bone, #FFFFFF);
}

.altrd-drop--bone .altrd-drop__footer-link:hover {
  background: var(--color-altrd-ink, #000000);
  color: var(--color-altrd-bone, #FFFFFF);
  border-color: var(--color-altrd-ink, #000000);
}
{% endstylesheet %}

<script>
  (function () {
    var track = document.getElementById('AltrdDropTrack-{{ section.id }}');
    if (!track) return;
    var prev = document.getElementById('AltrdDropPrev-{{ section.id }}');
    var next = document.getElementById('AltrdDropNext-{{ section.id }}');

    function step() {
      var card = track.querySelector('.altrd-drop__card');
      if (!card) return track.clientWidth;
      var styles = getComputedStyle(track);
      var gap = parseFloat(styles.columnGap || styles.gap || 0) || 0;
      return card.getBoundingClientRect().width + gap;
    }
    function sync() {
      var max = track.scrollWidth - track.clientWidth - 2;
      if (prev) prev.disabled = track.scrollLeft <= 2;
      if (next) next.disabled = track.scrollLeft >= max;
    }
    if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -step(), behavior: 'smooth' }); });
    if (next) next.addEventListener('click', function () { track.scrollBy({ left: step(), behavior: 'smooth' }); });

    var ticking = false;
    track.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () { sync(); ticking = false; });
    }, { passive: true });

    var down = false, startX = 0, startScroll = 0, moved = false;
    track.addEventListener('pointerdown', function (e) {
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      down = true; moved = false; track.classList.add('is-dragging');
      startX = e.clientX; startScroll = track.scrollLeft;
      track.setPointerCapture(e.pointerId);
    });
    track.addEventListener('pointermove', function (e) {
      if (!down) return;
      if (Math.abs(e.clientX - startX) > 4) moved = true;
      track.scrollLeft = startScroll - (e.clientX - startX);
    });
    function end() { if (!down) return; down = false; track.classList.remove('is-dragging'); sync(); }
    track.addEventListener('pointerup', end);
    track.addEventListener('pointercancel', end);
    track.addEventListener('pointerleave', end);
    track.addEventListener('click', function (e) { if (moved) { e.preventDefault(); e.stopPropagation(); } }, true);

    window.addEventListener('resize', sync);
    sync();
  })();
</script>

{% schema %}
{
  "name": "ALTRD — Featured drop",
  "class": "altrd-drop-section",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Drop details"
    },
    {
      "type": "text",
      "id": "drop_label",
      "label": "Drop label",
      "default": "Drop 001"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Defaults to collection title if blank."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "One idea. Worn differently."
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "header",
      "content": "View all"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all'",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View all"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_style",
      "label": "Color style",
      "options": [
        { "value": "ink",  "label": "Ink (dark)" },
        { "value": "bone", "label": "Bone (light)" }
      ],
      "default": "bone"
    }
  ],
  "presets": [
    {
      "name": "ALTRD — Featured drop",
      "settings": {
        "drop_label": "Drop 001",
        "tagline": "One idea. Worn differently.",
        "products_to_show": 4,
        "show_view_all": true,
        "view_all_label": "View all",
        "color_style": "bone"
      }
    }
  ]
}
{% endschema %}
