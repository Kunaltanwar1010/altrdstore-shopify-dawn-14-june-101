{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-badge.css' | asset_url | stylesheet_tag }}

{%- style -%}
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}

/* --- ALTRD related products editorial header --- */
.altrd-rp__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}
.altrd-rp__header-left { flex: 1 1 auto; min-width: 0; }
.altrd-rp__eyebrow {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-altrd-hivis, #E8FF52);
  {%- if section.settings.color_style == 'bone' -%}
  color: rgba(11,11,11,0.45);
  {%- endif -%}
  margin: 0 0 0.625rem;
}
.altrd-rp__heading {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(2rem, 4vw, 3.75rem);
  font-weight: 400;
  line-height: 0.93;
  text-transform: uppercase;
  letter-spacing: 0.01em;
  margin: 0;
  {%- if section.settings.color_style == 'ink' -%}
  color: #F4EFE6;
  {%- else -%}
  color: #0B0B0B;
  {%- endif -%}
}
.altrd-rp__cta {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.8125rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 0.75rem 1.5rem;
  border: 1.5px solid;
  transition: background 0.18s ease, color 0.18s ease;
  white-space: nowrap;
  {%- if section.settings.color_style == 'ink' -%}
  color: #0B0B0B;
  background: var(--color-altrd-hivis, #E8FF52);
  border-color: var(--color-altrd-hivis, #E8FF52);
  {%- else -%}
  color: #0B0B0B;
  background: transparent;
  border-color: #0B0B0B;
  {%- endif -%}
}
.altrd-rp__cta:hover {
  {%- if section.settings.color_style == 'ink' -%}
  background: #fff;
  border-color: #fff;
  {%- else -%}
  background: #0B0B0B;
  color: #F4EFE6;
  {%- endif -%}
}
.altrd-rp__cta svg { transition: transform 0.18s ease; }
.altrd-rp__cta:hover svg { transform: translateX(3px); }

/* --- Grid --- */
.altrd-rp__grid {
  display: grid;
  gap: 1.25rem;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
}
@media screen and (max-width: 989px) {
  .altrd-rp__grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
}
@media screen and (max-width: 549px) {
  .altrd-rp__grid {
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: 0.75rem;
  }
}

/* --- Card overrides for ALTRD brand --- */
.altrd-rp-section .card-wrapper { border-radius: 0; }
.altrd-rp-section .card__heading {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.02em;
}
.altrd-rp-section .price__sale { font-weight: 700; }
.altrd-rp-section .badge--sale {
  background: var(--color-altrd-hivis, #E8FF52);
  color: #0B0B0B;
  border-radius: 0;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.5625rem;
  font-weight: 700;
  letter-spacing: 0.08em;
}

/* --- Empty state --- */
.altrd-rp__empty {
  text-align: center;
  padding: 3rem 0;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.9375rem;
  color: rgba(11,11,11,0.45);
}
{%- endstyle -%}

{%- liquid
  assign color_bg = '#F4EFE6'
  assign color_text = '#0B0B0B'
  if section.settings.color_style == 'ink'
    assign color_bg = '#0B0B0B'
    assign color_text = '#F4EFE6'
  endif

  assign source_collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show | default: 4
-%}

<section
  class="altrd-rp-section section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  style="background: {{ color_bg }}; color: {{ color_text }};"
  aria-label="{{ section.settings.heading | default: 'Related products' | escape }}"
>
  <div class="page-width">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.cta_label != blank -%}
      <div class="altrd-rp__header">
        <div class="altrd-rp__header-left">
          {%- if section.settings.eyebrow != blank -%}
            <p class="altrd-rp__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="altrd-rp__heading">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
          <a href="{{ section.settings.cta_link }}" class="altrd-rp__cta">
            {{ section.settings.cta_label | escape }}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if source_collection != blank and source_collection.products_count > 0 -%}
      {%- assign skip_card_product_styles = false -%}
      <ul class="altrd-rp__grid" role="list">
        {%- for product in source_collection.products limit: products_to_show -%}
          <li>
            {%- render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              image_shape: 'default',
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              skip_styles: skip_card_product_styles
            -%}
            {%- assign skip_card_product_styles = true -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- elsif source_collection == blank -%}
      {%- if request.design_mode -%}
        <p class="altrd-rp__empty">Select a collection in the section settings to display products here.</p>
      {%- endif -%}
    {%- else -%}
      {%- if request.design_mode -%}
        <p class="altrd-rp__empty">The selected collection has no products.</p>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "ALTRD — Related products",
  "tag": "div",
  "class": "altrd-related-products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "placeholder": "More from this drop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You might also like"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "View all button label",
      "placeholder": "View the full drop"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "View all link"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "header",
      "content": "Card options"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "portrait",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait (2:3)" },
        { "value": "square", "label": "Square (1:1)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show hover image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating",
      "default": false
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_style",
      "label": "Background",
      "default": "bone",
      "options": [
        { "value": "bone", "label": "Bone (light)" },
        { "value": "ink", "label": "Ink (dark)" }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "ALTRD — Related products",
      "settings": {
        "eyebrow": "More from this drop",
        "heading": "You might also like",
        "products_to_show": 4,
        "columns_desktop": 4,
        "columns_mobile": "2",
        "image_ratio": "portrait",
        "show_secondary_image": true,
        "color_style": "bone"
      }
    }
  ]
}
{% endschema %}
