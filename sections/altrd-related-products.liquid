{%- liquid
  assign source_collection = section.settings.collection
  assign products_to_show  = section.settings.products_to_show | default: 4
  assign color_style       = section.settings.color_style | default: 'white'
-%}

{%- style -%}
/* === ALTRD Related Products === */
.altrd-rp {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  border-top: 1px solid rgba(0,0,0,0.08);
}
@media screen and (max-width: 749px) {
  .altrd-rp {
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 0 {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
}
.altrd-rp--ink   { background: #0B0B0B; color: #F4EFE6; border-top-color: rgba(255,255,255,0.08); }
.altrd-rp--bone  { background: #F4EFE6; color: #0B0B0B; }
.altrd-rp--white { background: #FFFFFF; color: #0B0B0B; }

/* Header */
.altrd-rp__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}
@media screen and (max-width: 749px) {
  .altrd-rp__header { margin-bottom: 1.5rem; }
}
.altrd-rp__eyebrow {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin: 0 0 0.625rem;
  opacity: 0.45;
}
.altrd-rp--ink .altrd-rp__eyebrow { color: var(--color-altrd-hivis, #E8FF52); opacity: 1; }
.altrd-rp__heading {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(2rem, 4.5vw, 3.75rem);
  font-weight: 400;
  line-height: 0.93;
  text-transform: uppercase;
  margin: 0;
}
.altrd-rp__view-all {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  color: inherit;
  border-bottom: 1.5px solid currentColor;
  padding-bottom: 2px;
  transition: gap 0.18s ease;
  white-space: nowrap;
}
.altrd-rp__view-all:hover { gap: 0.875rem; }
@media screen and (max-width: 749px) { .altrd-rp__view-all { display: none; } }

/* Desktop grid */
.altrd-rp__grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: 2rem 1.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
}
@media screen and (min-width: 750px) and (max-width: 989px) {
  .altrd-rp__grid { grid-template-columns: repeat(2, 1fr); gap: 1.75rem 1.25rem; }
}

/* Mobile: horizontal snap carousel */
@media screen and (max-width: 749px) {
  .altrd-rp__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 0.875rem;
    padding: 0 1.5rem 0.75rem;
    margin: 0 -1.5rem;
    cursor: grab;
    user-select: none;
  }
  .altrd-rp__grid::-webkit-scrollbar { display: none; }
  .altrd-rp__grid.altrd-rp__grid--dragging {
    cursor: grabbing;
    scroll-snap-type: none;
  }
  .altrd-rp__grid > li {
    flex: 0 0 78vw;
    max-width: 19rem;
    scroll-snap-align: start;
    pointer-events: auto;
  }
  .altrd-rp__grid.altrd-rp__grid--dragging > li { pointer-events: none; }
  /* Peek indicator — trailing padding via last card */
  .altrd-rp__grid > li:last-child { margin-right: 0.5rem; }
}

/* Dot indicators — mobile carousel only */
.altrd-rp__dots {
  display: none;
  align-items: center;
  justify-content: center;
  gap: 0.4375rem;
  margin-top: 1.125rem;
}
@media screen and (max-width: 749px) {
  .altrd-rp__dots { display: flex; }
}
.altrd-rp__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.25;
  transform: scale(1);
  transition: opacity 0.2s ease, transform 0.2s ease;
}
.altrd-rp__dot--active { opacity: 1; transform: scale(1.4); }

/* === Card: identical to altrd-featured-drop === */
.altrd-rp__card {
  display: block;
  text-decoration: none;
  color: inherit;
}
.altrd-rp__card-media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3 / 4;
  background: #1a1a1a;
}
.altrd-rp--bone  .altrd-rp__card-media { background: #E8E3DA; }
.altrd-rp--white .altrd-rp__card-media { background: #F0F0F0; }
.altrd-rp__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.altrd-rp__card:hover .altrd-rp__card-img { transform: scale(1.05); }
.altrd-rp__card-img--alt {
  position: absolute;
  inset: 0;
  opacity: 0;
  z-index: 1;
  transition: opacity 0.5s ease, transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.altrd-rp__card:hover .altrd-rp__card-img--alt { opacity: 1; }
.altrd-rp__card-badges {
  position: absolute;
  top: 0.875rem;
  left: 0.875rem;
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  z-index: 2;
}
.altrd-rp__badge {
  display: inline-block;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.375rem 0.75rem;
}
.altrd-rp__badge--sold-out { background: rgba(0,0,0,0.65); color: #fff; }
.altrd-rp__badge--sale { background: var(--color-altrd-hivis, #E8FF52); color: #0B0B0B; }
.altrd-rp__card-hover {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 1.25rem;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 55%);
  opacity: 0;
  transition: opacity 0.22s ease;
  z-index: 3;
}
.altrd-rp__card:hover .altrd-rp__card-hover { opacity: 1; }
@media (hover: none) { .altrd-rp__card-hover { display: none; } }
.altrd-rp__card-shop {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #0B0B0B;
  background: #F4EFE6;
  padding: 0.5rem 1.25rem;
}
.altrd-rp__card-info {
  padding: 1.25rem 0 0.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.altrd-rp__card-name {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1rem;
  font-weight: 500;
  line-height: 1.35;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.altrd-rp__card-pricing {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.altrd-rp__card-price {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1.0625rem;
  font-weight: 700;
}
.altrd-rp--ink   .altrd-rp__card-price--sale { color: var(--color-altrd-hivis, #E8FF52); }
.altrd-rp--bone  .altrd-rp__card-price--sale { color: #b33; }
.altrd-rp--white .altrd-rp__card-price--sale { color: #b33; }
.altrd-rp__card-compare {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.9375rem;
  font-weight: 400;
  opacity: 0.38;
  text-decoration: line-through;
}

/* Footer view-all (mobile only) */
.altrd-rp__footer {
  display: none;
  text-align: center;
  margin-top: 1.75rem;
}
@media screen and (max-width: 749px) { .altrd-rp__footer { display: block; } }
.altrd-rp__footer-link {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  color: inherit;
  padding: 0.875rem 2.25rem;
  border: 1.5px solid currentColor;
  transition: background 0.18s ease, color 0.18s ease;
}
.altrd-rp--ink   .altrd-rp__footer-link:hover { background: #F4EFE6; color: #0B0B0B; }
.altrd-rp--bone  .altrd-rp__footer-link:hover { background: #0B0B0B; color: #F4EFE6; }
.altrd-rp--white .altrd-rp__footer-link:hover { background: #0B0B0B; color: #FFFFFF; }

/* Empty state (editor only) */
.altrd-rp__empty {
  text-align: center;
  padding: 3rem 0;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.9375rem;
  opacity: 0.45;
}
{%- endstyle -%}

<div class="altrd-rp altrd-rp--{{ color_style }}">
  <div class="page-width">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.cta_label != blank -%}
      <div class="altrd-rp__header">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            <p class="altrd-rp__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="altrd-rp__heading">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
          <a href="{{ section.settings.cta_link }}" class="altrd-rp__view-all">
            {{ section.settings.cta_label | escape }}
            <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3 9h12M10 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if source_collection != blank and source_collection.products_count > 0 -%}
      <ul class="altrd-rp__grid" id="AltrdRPTrack-{{ section.id }}" role="list">
        {%- for product in source_collection.products limit: products_to_show -%}
          {%- liquid
            assign is_on_sale = false
            if product.compare_at_price > product.price
              assign is_on_sale = true
            endif
          -%}
          <li>
            <a
              href="{{ product.url }}"
              class="altrd-rp__card{% unless product.available %} altrd-rp__card--sold-out{% endunless %}"
              aria-label="{{ product.title | escape }}"
            >
              <div class="altrd-rp__card-media">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 900
                    | image_tag:
                      class: 'altrd-rp__card-img',
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 25vw, 75vw',
                      widths: '375, 550, 750, 900',
                      alt: product.featured_image.alt | escape
                  }}
                  {%- if product.images.size > 1 and section.settings.show_secondary_image -%}
                    {{
                      product.images[1]
                      | image_url: width: 900
                      | image_tag:
                        class: 'altrd-rp__card-img altrd-rp__card-img--alt',
                        loading: 'lazy',
                        sizes: '(min-width: 990px) 25vw, 75vw',
                        widths: '375, 550, 750, 900',
                        alt: product.images[1].alt | escape
                    }}
                  {%- endif -%}
                {%- else -%}
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'altrd-rp__card-placeholder' }}
                {%- endif -%}

                <div class="altrd-rp__card-badges">
                  {%- unless product.available -%}
                    <span class="altrd-rp__badge altrd-rp__badge--sold-out">Sold out</span>
                  {%- endunless -%}
                  {%- if is_on_sale and product.available -%}
                    <span class="altrd-rp__badge altrd-rp__badge--sale">Sale</span>
                  {%- endif -%}
                </div>

                <div class="altrd-rp__card-hover" aria-hidden="true">
                  <span class="altrd-rp__card-shop">Shop now</span>
                </div>
              </div>

              <div class="altrd-rp__card-info">
                <p class="altrd-rp__card-name">{{ product.title | escape }}</p>
                <div class="altrd-rp__card-pricing">
                  <span class="altrd-rp__card-price{% if is_on_sale %} altrd-rp__card-price--sale{% endif %}">
                    {{- product.price | money -}}
                  </span>
                  {%- if is_on_sale -%}
                    <s class="altrd-rp__card-compare">{{ product.compare_at_price | money }}</s>
                  {%- endif -%}
                </div>
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>

      {%- if source_collection.products_count > 1 -%}
        <div class="altrd-rp__dots" id="AltrdRPDots-{{ section.id }}" aria-hidden="true">
          {%- for product in source_collection.products limit: products_to_show -%}
            <span class="altrd-rp__dot{% if forloop.first %} altrd-rp__dot--active{% endif %}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <div class="altrd-rp__footer">
          <a href="{{ section.settings.cta_link }}" class="altrd-rp__footer-link">
            {{ section.settings.cta_label | escape }}
            <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3 9h12M10 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      {%- endif -%}

      <script>
        (function () {
          var track = document.getElementById('AltrdRPTrack-{{ section.id }}');
          var dotsWrap = document.getElementById('AltrdRPDots-{{ section.id }}');
          if (!track) return;
          var dots = dotsWrap ? Array.prototype.slice.call(dotsWrap.querySelectorAll('.altrd-rp__dot')) : [];

          function updateDots() {
            if (!dots.length) return;
            var cards = track.querySelectorAll('li');
            var trackLeft = track.getBoundingClientRect().left;
            var closest = 0;
            var closestDist = Infinity;
            cards.forEach(function (card, i) {
              var dist = Math.abs(card.getBoundingClientRect().left - trackLeft);
              if (dist < closestDist) {
                closestDist = dist;
                closest = i;
              }
            });
            dots.forEach(function (dot, i) {
              dot.classList.toggle('altrd-rp__dot--active', i === closest);
            });
          }

          var ticking = false;
          track.addEventListener('scroll', function () {
            if (ticking) return;
            ticking = true;
            window.requestAnimationFrame(function () {
              updateDots();
              ticking = false;
            });
          }, { passive: true });

          /* Pointer drag-to-scroll so a mouse/trackpad can swipe the carousel too */
          var isDown = false;
          var startX = 0;
          var startScroll = 0;

          track.addEventListener('pointerdown', function (e) {
            if (e.pointerType === 'mouse' && e.button !== 0) return;
            isDown = true;
            track.classList.add('altrd-rp__grid--dragging');
            startX = e.clientX;
            startScroll = track.scrollLeft;
            track.setPointerCapture(e.pointerId);
          });

          track.addEventListener('pointermove', function (e) {
            if (!isDown) return;
            var dx = e.clientX - startX;
            track.scrollLeft = startScroll - dx;
          });

          function endDrag(e) {
            if (!isDown) return;
            isDown = false;
            track.classList.remove('altrd-rp__grid--dragging');
            updateDots();
          }
          track.addEventListener('pointerup', endDrag);
          track.addEventListener('pointercancel', endDrag);
          track.addEventListener('pointerleave', endDrag);
        })();
      </script>

    {%- elsif request.design_mode -%}
      <p class="altrd-rp__empty">
        {%- if source_collection == blank -%}
          Select a collection in the section settings to display products here.
        {%- else -%}
          The selected collection has no products.
        {%- endif -%}
      </p>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "ALTRD — Related products",
  "tag": "div",
  "class": "altrd-related-products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "placeholder": "More from this drop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You might also like"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "View all button label",
      "placeholder": "View the full drop"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "View all link"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show hover / alt image",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_style",
      "label": "Background",
      "default": "white",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "bone",  "label": "Bone (light)" },
        { "value": "ink",   "label": "Ink (dark)" }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "ALTRD — Related products",
      "settings": {
        "eyebrow": "More from this drop",
        "heading": "You might also like",
        "products_to_show": 4,
        "columns_desktop": 4,
        "show_secondary_image": true,
        "color_style": "white"
      }
    }
  ]
}
{% endschema %}
