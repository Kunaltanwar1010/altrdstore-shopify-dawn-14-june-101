{%- liquid
  assign mode = section.settings.background_mode | default: 'dark'
  if mode == 'light'
    assign af_bg = '#FFFFFF'
    assign af_tx = '#0B0B0B'
    assign af_line = 'rgba(0,0,0,0.12)'
    assign af_muted = 'rgba(0,0,0,0.58)'
    assign af_field = 'rgba(0,0,0,0.04)'
    assign pay_filter = 'grayscale(1)'
    assign auto_logo_filter = 'none'
  else
    assign af_bg = '#0B0B0B'
    assign af_tx = '#FFFFFF'
    assign af_line = 'rgba(255,255,255,0.16)'
    assign af_muted = 'rgba(255,255,255,0.60)'
    assign af_field = 'rgba(255,255,255,0.06)'
    assign pay_filter = 'grayscale(1) brightness(0) invert(1)'
    assign auto_logo_filter = 'brightness(0) invert(1)'
  endif

  assign current_year = 'now' | date: '%Y'

  assign service_items = section.blocks | where: 'type', 'service_item'
  assign menu_columns  = section.blocks | where: 'type', 'menu_column'
  assign rotation_blocks = section.blocks | where: 'type', 'on_rotation'
-%}

{%- style -%}
  /* === ALTRD custom === */
  #shopify-section-{{ section.id }} {
    --af-bg: {{ af_bg }};
    --af-tx: {{ af_tx }};
    --af-line: {{ af_line }};
    --af-muted: {{ af_muted }};
    --af-field: {{ af_field }};
    --af-logo-filter: {{ auto_logo_filter }};
  }
  .altrd-footer {
    background: var(--af-bg);
    color: var(--af-tx);
    margin-top: {{ section.settings.margin_top }}px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  }
  .altrd-footer *,
  .altrd-footer *::before,
  .altrd-footer *::after { box-sizing: border-box; }

  /* Service strip */
  .altrd-footer__service {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    padding-bottom: 2.75rem;
    border-bottom: 1px solid var(--af-line);
  }
  .altrd-footer__service-item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }
  .altrd-footer__service-icon {
    flex-shrink: 0;
    width: 1.75rem;
    height: 1.75rem;
  }
  .altrd-footer__service-icon svg { width: 100%; height: 100%; stroke: var(--af-tx); fill: none; }
  .altrd-footer__service-title {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 0 0 0.2rem;
    color: var(--af-tx);
  }
  .altrd-footer__service-sub {
    font-size: 0.8125rem;
    line-height: 1.45;
    margin: 0;
    color: var(--af-muted);
  }

  /* Newsletter band */
  .altrd-footer__news {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 2.5rem 4rem;
    align-items: center;
    padding: 3rem 0;
    border-bottom: 1px solid var(--af-line);
  }
  .altrd-footer__logo-img { display: block; height: auto; max-width: 100%; }
  .altrd-footer__logo-img--auto { filter: var(--af-logo-filter); }
  .altrd-footer__logo-text {
    font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
    font-size: 2.75rem;
    line-height: 1;
    text-transform: uppercase;
    margin: 0;
    color: var(--af-tx);
  }
  .altrd-footer__about {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--af-muted);
    max-width: 46ch;
  }
  .altrd-footer__about p { margin: 0 0 0.75rem; }
  .altrd-footer__about p:last-child { margin-bottom: 0; }
  .altrd-footer__about a { color: var(--af-tx); }
  .altrd-footer__news-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--af-muted);
    margin: 1.5rem 0 0.5rem;
  }
  .altrd-footer__news-heading {
    font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: 0.98;
    text-transform: uppercase;
    margin: 0;
    color: var(--af-tx);
  }
  .altrd-footer__form-row {
    display: flex;
    border-bottom: 1.5px solid var(--af-tx);
  }
  .altrd-footer__input {
    flex: 1 1 auto;
    background: transparent;
    border: 0;
    color: var(--af-tx);
    font-family: inherit;
    font-size: 1rem;
    padding: 0.75rem 0.25rem;
    outline: none;
  }
  .altrd-footer__input::placeholder { color: var(--af-muted); }
  .altrd-footer__submit {
    flex-shrink: 0;
    background: transparent;
    border: 0;
    color: var(--af-tx);
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0 0.5rem;
    cursor: pointer;
  }
  .altrd-footer__submit:hover { text-decoration: underline; text-underline-offset: 3px; }
  .altrd-footer__fineprint {
    font-size: 0.75rem;
    color: var(--af-muted);
    margin: 0.875rem 0 0;
  }
  .altrd-footer__form-msg {
    font-size: 0.8125rem;
    margin: 0.625rem 0 0;
    color: var(--af-tx);
  }

  /* Top grid: logo + menu columns */
  .altrd-footer__top {
    display: grid;
    grid-template-columns: 1.3fr repeat(3, 1fr);
    gap: 2.5rem 3rem;
    padding: 3rem 0 2.5rem;
  }
  .altrd-footer__top-logo { display: flex; align-items: flex-start; }
  .altrd-footer__col { border: 0; }
  .altrd-footer__col-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
  }
  .altrd-footer__col-summary::-webkit-details-marker { display: none; }
  .altrd-footer__col-heading {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--af-tx);
    margin: 0 0 1.25rem;
  }
  .altrd-footer__col-chevron { width: 1rem; height: 1rem; stroke: var(--af-tx); fill: none; transition: transform 0.2s ease; }
  .altrd-footer__col[open] .altrd-footer__col-chevron { transform: rotate(180deg); }
  .altrd-footer__col-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .altrd-footer__col-link {
    font-size: 0.9375rem;
    color: var(--af-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .altrd-footer__col-link:hover { color: var(--af-tx); text-decoration: underline; text-underline-offset: 3px; }

  /* On rotation */
  .altrd-footer__rotation {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--af-line);
  }
  .altrd-footer__rotation-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .altrd-footer__rotation-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--af-muted);
    margin: 0;
  }
  .altrd-footer__rotation-link {
    font-size: 0.8125rem;
    color: var(--af-tx);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .altrd-footer__rotation-embed iframe { width: 100%; border: 0; border-radius: 0; display: block; }

  /* Trademark band */
  .altrd-footer__trademark {
    padding: 1.75rem 0;
    border-top: 1px solid var(--af-line);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--af-muted);
  }
  .altrd-footer__trademark a { color: var(--af-tx); }

  /* Social band */
  .altrd-footer__social-band {
    padding: 1.5rem 0;
    border-top: 1px solid var(--af-line);
  }
  .altrd-footer__social { display: flex; align-items: center; gap: 0.625rem; flex-wrap: wrap; }
  .altrd-footer__social-link {
    width: 2.25rem; height: 2.25rem;
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--af-line);
    color: var(--af-tx);
    border-radius: 50%;
    transition: opacity 0.15s ease;
  }
  .altrd-footer__social-link:hover { opacity: 0.6; }
  .altrd-footer__social-link svg { width: 1rem; height: 1rem; fill: currentColor; }

  .altrd-footer__utils { display: flex; align-items: center; justify-content: center; gap: 1.25rem 1.75rem; flex-wrap: wrap; }
  .altrd-footer__payment { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; list-style: none; margin: 0; padding: 0; }
  .altrd-footer__payment .icon { width: 2.3rem; height: 1.5rem; filter: {{ pay_filter }}; }
  .altrd-footer__localization { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .altrd-footer__localization .caption-large { color: var(--af-muted); }

  /* Bottom band: copyright + policies + utils (centered) */
  .altrd-footer__bottom-band {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--af-line);
  }
  .altrd-footer__copyright {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem 1.25rem;
    flex-wrap: wrap;
    text-align: center;
  }
  .altrd-footer__copyright small,
  .altrd-footer__copyright a {
    font-size: 0.75rem;
    color: var(--af-muted);
    text-decoration: none;
  }
  .altrd-footer__copyright a:hover { color: var(--af-tx); text-decoration: underline; text-underline-offset: 3px; }
  .altrd-footer__policies { display: flex; gap: 1.25rem; flex-wrap: wrap; list-style: none; margin: 0; padding: 0; }

  /* Mobile */
  @media screen and (max-width: 989px) {
    .altrd-footer__top { grid-template-columns: 1fr; gap: 0; padding: 2rem 0 0.5rem; }
    .altrd-footer__top-logo { justify-content: center; padding: 0.5rem 0 1.75rem; }
    .altrd-footer__col {
      border-top: 1px solid var(--af-line);
      padding: 1.125rem 0;
    }
    .altrd-footer__col-heading { margin: 0; }
    .altrd-footer__col-list { padding-top: 1.125rem; }
  }
  @media screen and (max-width: 749px) {
    .altrd-footer__service { grid-template-columns: 1fr 1fr; gap: 1.5rem 1rem; }
  }

  /* Desktop: columns always open, no toggle */
  @media screen and (min-width: 990px) {
    .altrd-footer__col-summary { pointer-events: none; }
    .altrd-footer__col-chevron { display: none; }
    .altrd-footer__col > .altrd-footer__col-list { display: flex !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .altrd-footer__col-chevron { transition: none; }
  }
{%- endstyle -%}

<footer class="altrd-footer">
  <div class="page-width">

    {%- if section.settings.show_service_strip and service_items.size > 0 -%}
      <div class="altrd-footer__service">
        {%- for block in service_items -%}
          <div class="altrd-footer__service-item" {{ block.shopify_attributes }}>
            <span class="altrd-footer__service-icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'chat' -%}
                  <svg viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5z"/></svg>
                {%- when 'truck' -%}
                  <svg viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="13" height="11"/><path d="M14 9h4l3 3v5h-7z"/><circle cx="6" cy="18.5" r="1.6"/><circle cx="17.5" cy="18.5" r="1.6"/></svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 5.6a5 5 0 0 0-7.1 0L12 7.3l-1.7-1.7a5 5 0 1 0-7.1 7.1L12 21l8.8-8.3a5 5 0 0 0 0-7.1z"/></svg>
                {%- when 'lock' -%}
                  <svg viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="10.5" width="16" height="10" rx="1.5"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/></svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.4 8.5-8 11-4.6-2.5-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg>
                {%- when 'refresh' -%}
                  <svg viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-2.6-6.4"/><path d="M21 3v5h-5"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
              {%- endcase -%}
            </span>
            <div>
              {%- if block.settings.title != blank -%}
                <p class="altrd-footer__service-title">{{ block.settings.title | escape }}</p>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <p class="altrd-footer__service-sub">{{ block.settings.subtext | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_brand or menu_columns.size > 0 -%}
      <div class="altrd-footer__top">
        {%- if section.settings.show_brand -%}
          <div class="altrd-footer__top-logo">
            {%- if section.settings.footer_logo != blank -%}
              {%- assign logo_h = section.settings.footer_logo_width | divided_by: section.settings.footer_logo.aspect_ratio -%}
              {{
                section.settings.footer_logo
                | image_url: width: 600
                | image_tag:
                  class: 'altrd-footer__logo-img',
                  widths: '120, 240, 360, 480, 600',
                  width: section.settings.footer_logo_width,
                  height: logo_h,
                  loading: 'lazy',
                  alt: shop.name | escape
              }}
            {%- elsif settings.logo != blank -%}
              {%- assign logo_h = section.settings.footer_logo_width | divided_by: settings.logo.aspect_ratio -%}
              {{
                settings.logo
                | image_url: width: 600
                | image_tag:
                  class: 'altrd-footer__logo-img altrd-footer__logo-img--auto',
                  widths: '120, 240, 360, 480, 600',
                  width: section.settings.footer_logo_width,
                  height: logo_h,
                  loading: 'lazy',
                  alt: shop.name | escape
              }}
            {%- else -%}
              <p class="altrd-footer__logo-text">{{ shop.name }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- for block in menu_columns -%}
          <details class="altrd-footer__col" open {{ block.shopify_attributes }}>
            <summary class="altrd-footer__col-summary">
              <h3 class="altrd-footer__col-heading">{{ block.settings.heading | escape }}</h3>
              <svg class="altrd-footer__col-chevron" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            {%- if block.settings.menu != blank -%}
              <ul class="altrd-footer__col-list">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}" class="altrd-footer__col-link">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_on_rotation and rotation_blocks.size > 0 -%}
      {%- for block in rotation_blocks -%}
        <div class="altrd-footer__rotation" {{ block.shopify_attributes }}>
          <div class="altrd-footer__rotation-head">
            <p class="altrd-footer__rotation-label">{{ block.settings.heading | default: 'On rotation' | escape }}</p>
            {%- if block.settings.link_url != blank and block.settings.link_label != blank -%}
              <a href="{{ block.settings.link_url }}" class="altrd-footer__rotation-link" target="_blank" rel="noopener">{{ block.settings.link_label | escape }}</a>
            {%- endif -%}
          </div>
          {%- if block.settings.playlist_embed != blank -%}
            <div class="altrd-footer__rotation-embed">
              <iframe
                src="{{ block.settings.playlist_embed }}"
                height="{{ block.settings.embed_height | default: 152 }}"
                loading="lazy"
                allow="encrypted-media"
                title="{{ block.settings.heading | default: 'On rotation' | escape }}"
              ></iframe>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}

    {%- if section.settings.trademark_text != blank -%}
      <div class="altrd-footer__trademark rte">{{ section.settings.trademark_text }}</div>
    {%- endif -%}

    {%- liquid
      assign ig_url = section.settings.social_instagram | default: settings.social_instagram_link
      assign fb_url = section.settings.social_facebook | default: settings.social_facebook_link
      assign x_url  = settings.social_twitter_link
    -%}
    {%- if section.settings.show_social and ig_url != blank or fb_url != blank or x_url != blank -%}
      <div class="altrd-footer__social-band">
        <div class="altrd-footer__social">
          {%- if ig_url != blank -%}
            <a href="{{ ig_url }}" class="altrd-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if fb_url != blank -%}
            <a href="{{ fb_url }}" class="altrd-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
            </a>
          {%- endif -%}
          {%- if x_url != blank -%}
            <a href="{{ x_url }}" class="altrd-footer__social-link" target="_blank" rel="noopener" aria-label="X">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="altrd-footer__bottom-band">
      <div class="altrd-footer__copyright">
        <small>&copy; {{ current_year }} — {{ shop.name | link_to: routes.root_url }}</small>
        {%- if section.settings.show_policy -%}
          <ul class="altrd-footer__policies" role="list">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="altrd-footer__utils">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 or section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <div class="altrd-footer__localization isolate">
            {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
              <localization-form>
                {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                  <div>
                    <h2 class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                    {%- render 'country-localization', localPosition: 'FooterCountry' -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}
            {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
              <localization-form>
                {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                  <div>
                    <h2 class="caption-large text-body" id="FooterLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                    {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.payment_enable and shop.enabled_payment_types.size > 0 -%}
          <ul class="altrd-footer__payment" role="list">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            {%- for type in shop.enabled_payment_types -%}
              <li>{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>

  </div>
</footer>

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;
    var cols = section.querySelectorAll('.altrd-footer__col');
    if (!cols.length) return;
    var desktop = window.matchMedia('(min-width: 990px)');
    function sync() {
      cols.forEach(function (d) { d.open = desktop.matches; });
    }
    sync();
    if (desktop.addEventListener) {
      desktop.addEventListener('change', sync);
    } else if (desktop.addListener) {
      desktop.addListener(sync);
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "service_item",
      "name": "Service item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "chat",
          "options": [
            { "value": "chat", "label": "Chat / support" },
            { "value": "truck", "label": "Truck / dispatch" },
            { "value": "heart", "label": "Heart / loved" },
            { "value": "lock", "label": "Lock / secure" },
            { "value": "shield", "label": "Shield" },
            { "value": "refresh", "label": "Refresh / returns" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Customer service" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "Real people, real replies." }
      ]
    },
    {
      "type": "menu_column",
      "name": "Menu column",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "on_rotation",
      "name": "On rotation",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Label", "default": "On rotation" },
        {
          "type": "url",
          "id": "playlist_embed",
          "label": "Spotify embed URL",
          "info": "Spotify → Share → Embed → copy the src URL (https://open.spotify.com/embed/...)."
        },
        { "type": "range", "id": "embed_height", "min": 80, "max": 380, "step": 4, "unit": "px", "label": "Embed height", "default": 152 },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Full tape" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "background_mode",
      "label": "Color mode",
      "default": "dark",
      "info": "Strict black & white either way.",
      "options": [
        { "value": "dark", "label": "Dark (black bg / white text)" },
        { "value": "light", "label": "Light (white bg / black text)" }
      ]
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "checkbox",
      "id": "show_brand",
      "label": "Show logo column",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo",
      "info": "Use a white logo for the dark footer. Falls back to the theme logo (auto-inverted to white)."
    },
    {
      "type": "range",
      "id": "footer_logo_width",
      "min": 60,
      "max": 320,
      "step": 5,
      "unit": "px",
      "label": "Logo width",
      "default": 140
    },
    {
      "type": "header",
      "content": "Service strip"
    },
    {
      "type": "checkbox",
      "id": "show_service_strip",
      "label": "Show service strip",
      "default": true
    },
    {
      "type": "header",
      "content": "Newsletter (optional)"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "label": "t:sections.footer.settings.newsletter_enable.label",
      "default": false
    },
    {
      "type": "text",
      "id": "newsletter_label",
      "label": "Eyebrow label",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_fineprint",
      "label": "Fine print",
      "default": "Cannot be combined with other offers. Min. purchase ₹999."
    },
    {
      "type": "header",
      "content": "On rotation"
    },
    {
      "type": "checkbox",
      "id": "show_on_rotation",
      "label": "Show \"On rotation\" block",
      "default": false
    },
    {
      "type": "header",
      "content": "Legal"
    },
    {
      "type": "inline_richtext",
      "id": "trademark_text",
      "label": "Trademark / legal microcopy",
      "default": "ALTRD® and the ALTRD wordmark are trademarks of ALTRD. All designs, graphics and copy © ALTRD — unauthorized reproduction is prohibited."
    },
    {
      "type": "header",
      "content": "Social & bottom bar"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "t:sections.footer.settings.show_social.label",
      "default": true,
      "info": "Set the links below. X (Twitter) uses Theme settings → Social media."
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram link",
      "info": "Falls back to Theme settings → Social media if empty."
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook link",
      "info": "Falls back to Theme settings → Social media if empty."
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "label": "t:sections.footer.settings.enable_follow_on_shop.label",
      "default": true,
      "info": "t:sections.footer.settings.enable_follow_on_shop.info"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "label": "t:sections.footer.settings.enable_country_selector.label",
      "default": true,
      "info": "t:sections.footer.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "label": "t:sections.footer.settings.enable_language_selector.label",
      "default": true,
      "info": "t:sections.footer.settings.enable_language_selector.info"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "t:sections.footer.settings.payment_enable.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "label": "t:sections.footer.settings.show_policy.label",
      "default": true,
      "info": "t:sections.footer.settings.show_policy.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "default": {
    "blocks": [
      { "type": "service_item", "settings": { "icon": "chat", "title": "Customer service", "subtext": "Real people, real replies." } },
      { "type": "service_item", "settings": { "icon": "truck", "title": "Fast dispatch", "subtext": "Packed and shipped in 24–48 hrs." } },
      { "type": "service_item", "settings": { "icon": "heart", "title": "Trusted by 10K+", "subtext": "Closets that get it." } },
      { "type": "service_item", "settings": { "icon": "lock", "title": "Secure payment", "subtext": "Processed securely." } },
      { "type": "menu_column", "settings": { "heading": "Shop", "menu": "main-menu" } },
      { "type": "menu_column", "settings": { "heading": "Info", "menu": "footer" } },
      { "type": "menu_column", "settings": { "heading": "Support", "menu": "footer" } }
    ]
  }
}
{% endschema %}
