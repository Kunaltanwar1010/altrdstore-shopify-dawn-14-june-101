<section class="altrd-creator altrd-creator--{{ section.settings.color_style }} altrd-creator--{{ section.settings.layout }}">
  <div class="altrd-creator__inner page-width">

    <div class="altrd-creator__media">
      {%- if section.settings.image != blank -%}
        <div class="altrd-creator__img-wrap altrd-creator__img-wrap--{{ section.settings.image_ratio }}">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              class: 'altrd-creator__img',
              loading: 'lazy',
              sizes: '(min-width: 990px) 50vw, 100vw',
              widths: '375, 550, 750, 900, 1200'
          }}
        </div>
      {%- else -%}
        <div class="altrd-creator__img-wrap altrd-creator__img-wrap--portrait altrd-creator__img-placeholder">
          {{ 'person' | placeholder_svg_tag: 'altrd-creator__img-placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- if section.settings.creator_handle != blank -%}
  <a
    href="https://www.instagram.com/cs.ujjawalpahwa"
    target="_blank"
    rel="noopener noreferrer"
    class="altrd-creator__handle-tag"
  >
    {{ section.settings.creator_handle | escape }}
  </a>
{%- endif -%}
    </div>

    <div class="altrd-creator__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="altrd-creator__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="altrd-creator__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="altrd-creator__body rte">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.settings.creator_name != blank -%}
<div class="altrd-creator__byline">
  <a
    href="https://www.instagram.com/cs.ujjawalpahwa"
    target="_blank"
    rel="noopener noreferrer"
    class="altrd-creator__profile-link"
  >

    <div class="altrd-creator__profile-text">
      <span class="altrd-creator__name">
        {{ section.settings.creator_name | escape }}
      </span>

      {%- if section.settings.creator_title != blank -%}
        <span class="altrd-creator__title">
          {{ section.settings.creator_title | escape }}
        </span>
      {%- endif -%}
    </div>

    <div class="altrd-creator__instagram">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <rect x="3" y="3" width="18" height="18" rx="5"></rect>
    <circle cx="12" cy="12" r="4"></circle>
    <circle cx="17.5" cy="6.5" r="1"></circle>
  </svg>
</div>

  </a>
</div>
{%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_link | default: '#' }}"
          class="altrd-creator__cta"
        >
          <span>{{ section.settings.cta_label | escape }}</span>
          <svg class="altrd-creator__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% stylesheet %}

/* === ALTRD custom === */

.altrd-creator {
  padding: 5.5rem 0;
}

.altrd-creator--ink {
  background: var(--color-altrd-ink, #000000);
  color: var(--color-altrd-bone, #FFFFFF);
}

.altrd-creator--bone {
  background: var(--color-altrd-bone, #FFFFFF);
  color: var(--color-altrd-ink, #000000);
}

@media screen and (max-width: 749px) {
  .altrd-creator {
    padding: 4rem 0;
  }
}

.altrd-creator__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}

.altrd-creator--image_right .altrd-creator__media {
  order: 2;
}

.altrd-creator--image_right .altrd-creator__content {
  order: 1;
}

@media screen and (max-width: 749px) {
  .altrd-creator__inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .altrd-creator__media,
  .altrd-creator__content {
    order: unset;
  }
}

.altrd-creator__img-wrap {
  position: relative;
  overflow: hidden;
  width: 100%;
}

.altrd-creator__img-wrap--portrait {
  aspect-ratio: 3 / 4;
}

.altrd-creator__img-wrap--square {
  aspect-ratio: 1 / 1;
}

.altrd-creator__img-wrap::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 40%;
  background: var(--color-altrd-hivis, #FFFFFF);
  z-index: 1;
}

.altrd-creator__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.altrd-creator__img-placeholder {
  background: #111111;
}

.altrd-creator__img-placeholder-svg {
  width: 100%;
  height: 100%;
  opacity: 0.2;
}

/* HANDLE */

.altrd-creator__handle-tag {
  display: inline-block;
  margin-top: 1.25rem;
  text-decoration: none;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-altrd-hivis, #FFFFFF);
  transition: opacity 0.3s ease;
}

.altrd-creator__handle-tag:hover {
  opacity: 0.7;
}

.altrd-creator--bone .altrd-creator__handle-tag {
  color: var(--color-altrd-ink, #000000);
  opacity: 0.55;
}

/* EYEBROW */

.altrd-creator__eyebrow {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-altrd-hivis, #FFFFFF);
  margin: 0 0 1.5rem;
}

.altrd-creator--bone .altrd-creator__eyebrow {
  color: var(--color-altrd-ink, #000000);
  opacity: 0.45;
}

/* HEADING */

.altrd-creator__heading {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(3rem, 5.5vw, 6rem);
  font-weight: 400;
  line-height: 0.95;
  text-transform: uppercase;
  margin: 0 0 2.5rem;
  word-break: break-word;
}

.altrd-creator--ink .altrd-creator__heading {
  color: #fff;
}

.altrd-creator--bone .altrd-creator__heading {
  color: #000;
}

/* BODY */

.altrd-creator__body {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: clamp(1rem, 1.4vw, 1.125rem);
  font-weight: 400;
  line-height: 1.75;
  margin: 0 0 2.5rem;
  max-width: 58ch;
}

.altrd-creator--ink .altrd-creator__body {
  color: rgba(255,255,255,.78);
}

.altrd-creator--bone .altrd-creator__body {
  color: rgba(0,0,0,.72);
}

.altrd-creator__body p {
  margin: 0 0 1em;
}

.altrd-creator__body p:last-child {
  margin-bottom: 0;
}

/* CREATOR PROFILE */

.altrd-creator__byline {
  margin: 0 0 2rem;
  padding-left: 1rem;
  border-left: 2px solid #fff;
}

.altrd-creator--bone .altrd-creator__byline {
  border-left-color: #000;
}

.altrd-creator__profile-link {
  display: flex;
  align-items: center;
  gap: 16px;
  text-decoration: none;
  color: inherit;
}

.altrd-creator__profile-text {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.altrd-creator__name {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1;
  margin: 0;
}

.altrd-creator__title {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1rem;
  opacity: 0.65;
}

.altrd-creator__instagram {
  display: flex;
  align-items: center;
  justify-content: center;
}

.altrd-creator__instagram svg {
  width: 28px;
  height: 28px;
  opacity: 0.8;
  transition: all .3s ease;
}

.altrd-creator__profile-link:hover .altrd-creator__instagram svg {
  opacity: 1;
  transform: scale(1.1);
}

/* CTA */

.altrd-creator__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding-bottom: 3px;
  border-bottom: 1.5px solid #fff;
  color: #fff;
  transition: gap .2s ease;
}

.altrd-creator__cta:hover {
  gap: 1rem;
}

.altrd-creator__arrow {
  flex-shrink: 0;
  transition: transform .2s ease;
}

.altrd-creator__cta:hover .altrd-creator__arrow {
  transform: translateX(4px);
}

@media screen and (max-width: 749px) {

  .altrd-creator__name {
    font-size: 1.5rem;
  }

  .altrd-creator__title {
    font-size: 0.9rem;
  }

  .altrd-creator__instagram svg {
    width: 24px;
    height: 24px;
  }
}

{% endstylesheet %}
