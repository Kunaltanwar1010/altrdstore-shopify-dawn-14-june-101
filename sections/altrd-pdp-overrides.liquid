<div class="altrd-pdp-overrides" aria-hidden="true" hidden></div>

{% stylesheet %}
/* === ALTRD PDP brand overrides (product template only) === */

/* --- Typography --- */
product-info .product__title {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(2.25rem, 4vw, 5rem);
  font-weight: 400;
  line-height: 0.95;
  text-transform: uppercase;
  letter-spacing: 0.01em;
}

product-info .product__text.caption-with-letter-spacing,
product-info .product__text.body {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
}

/* Vendor shown as drop label */
product-info .product__text {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-altrd-hivis, #FFFFFF);
}

/* --- ATC button: ink default → hi-vis on hover --- */
product-info {
  --color-button: #000000;
  --color-button-text: #FFFFFF;
  --color-button-border: #000000;
}

product-info .product-form__submit {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.875rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border-radius: 0;
  min-height: 3.5rem;
  transition: background-color 0.2s ease, color 0.2s ease;
}

product-info .product-form__submit:not([disabled]):hover {
  background-color: var(--color-altrd-hivis, #FFFFFF);
  color: var(--color-altrd-ink, #000000);
  border-color: var(--color-altrd-hivis, #FFFFFF);
}

/* --- Variant buttons --- */
product-info .swatch__input:checked + .swatch__label,
product-info .button-swatch__input:checked + .button-swatch__label {
  border-color: var(--color-altrd-ink, #000000);
  background: var(--color-altrd-ink, #000000);
  color: var(--color-altrd-bone, #FFFFFF);
}

/* --- Price --- */
product-info .price--large {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 1.375rem;
  font-weight: 600;
  letter-spacing: 0.02em;
}

/* --- Description body text --- */
product-info .product__description {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.9375rem;
  line-height: 1.75;
}

/* --- Media: subtle ink border on active thumbnail --- */
product-info .product__media-item--thumbnail.product__media-item--active::after {
  border-color: var(--color-altrd-ink, #000000);
}
{% endstylesheet %}

