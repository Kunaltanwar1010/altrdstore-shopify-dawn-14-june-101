{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
  assign has_video = false
  if section.settings.video != blank
    assign has_video = true
  endif
  assign has_media = false
  if has_image or has_video
    assign has_media = true
  endif
-%}

<section
  class="altrd-hero altrd-hero--{{ section.settings.min_height }} altrd-hero--{{ section.settings.text_position }}{% unless has_media %} altrd-hero--ink{% endunless %}"
  style="--hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>
  <div class="altrd-hero__media">
    {%- if has_image -%}
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          class: 'altrd-hero__bg-img',
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '375, 750, 1100, 1500, 2000'
      }}
    {%- endif -%}

    {%- if has_video -%}
      <div class="altrd-hero__video-wrap">
        {{
          section.settings.video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            image_size: '2000x'
        }}
      </div>
    {%- endif -%}

    <div class="altrd-hero__overlay"></div>
  </div>

  <div class="altrd-hero__inner page-width">
    <div class="altrd-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="altrd-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="altrd-hero__heading">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="altrd-hero__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_link | default: '#' }}"
          class="altrd-hero__cta altrd-hero__cta--{{ section.settings.cta_style }}"
        >
          {{- section.settings.cta_label | escape -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
/* === ALTRD custom === */

.altrd-hero {
  position: relative;
  isolation: isolate;
  display: flex;
  align-items: center;
  width: 100%;
  overflow: hidden;
  background: var(--color-altrd-ink, #000000);
}

.altrd-hero--adapt  { min-height: 60vw; }
.altrd-hero--small  { min-height: 50vh; }
.altrd-hero--medium { min-height: 70vh; }
.altrd-hero--large  { min-height: 90vh; }
.altrd-hero--full   { min-height: 100svh; }

@media screen and (max-width: 749px) {
  .altrd-hero--adapt  { min-height: 75vw; }
  .altrd-hero--medium { min-height: 60vh; }
  .altrd-hero--large  { min-height: 80vh; }
}

.altrd-hero__media {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.altrd-hero__bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  z-index: 0;
}

.altrd-hero__video-wrap {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.altrd-hero__video-wrap video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

@media (prefers-reduced-motion: reduce) {
  .altrd-hero__video-wrap {
    display: none;
  }
}

.altrd-hero__overlay {
  position: absolute;
  inset: 0;
  background: #000000;
  opacity: var(--hero-overlay, 0.55);
  z-index: 2;
}

.altrd-hero--ink .altrd-hero__overlay {
  opacity: 0;
}

.altrd-hero__inner {
  position: relative;
  z-index: 3;
  width: 100%;
  padding-top: 7rem;
  padding-bottom: 7rem;
}

@media screen and (max-width: 749px) {
  .altrd-hero__inner {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }
}

.altrd-hero__content {
  max-width: 90rem;
}

.altrd-hero--center .altrd-hero__content {
  text-align: center;
  margin-inline: auto;
  max-width: 100%;
}

.altrd-hero__eyebrow {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: clamp(0.875rem, 1.2vw, 1rem);
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-altrd-hivis, #FFFFFF);
  margin: 0 0 1.5rem;
}

.altrd-hero__heading {
  font-family: var(--font-altrd-display, 'Bebas Neue', Impact, sans-serif);
  font-size: clamp(4.5rem, 12vw, 13rem);
  font-weight: 400;
  line-height: 0.92;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: var(--color-altrd-bone, #FFFFFF);
  margin: 0 0 2.5rem;
  word-break: break-word;
}

@media screen and (max-width: 749px) {
  .altrd-hero__heading {
    font-size: clamp(3.5rem, 16vw, 5rem);
  }
}

.altrd-hero__subheading {
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: clamp(1.0625rem, 1.7vw, 1.375rem);
  font-weight: 400;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.78);
  max-width: 52ch;
  margin: 0 0 3.5rem;
}

.altrd-hero--center .altrd-hero__subheading {
  margin-inline: auto;
}

.altrd-hero__cta {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-altrd-body, 'Space Grotesk', system-ui, sans-serif);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 1rem 2.25rem;
  border: 2px solid transparent;
  transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
}

.altrd-hero__cta--hivis {
  background: var(--color-altrd-hivis, #FFFFFF);
  color: var(--color-altrd-ink, #000000);
  border-color: var(--color-altrd-hivis, #FFFFFF);
}
.altrd-hero__cta--hivis:hover {
  background: transparent;
  color: var(--color-altrd-hivis, #FFFFFF);
}

.altrd-hero__cta--bone {
  background: var(--color-altrd-bone, #FFFFFF);
  color: var(--color-altrd-ink, #000000);
  border-color: var(--color-altrd-bone, #FFFFFF);
}
.altrd-hero__cta--bone:hover {
  background: transparent;
  color: var(--color-altrd-bone, #FFFFFF);
}

.altrd-hero__cta--outline {
  background: transparent;
  color: var(--color-altrd-bone, #FFFFFF);
  border-color: var(--color-altrd-bone, #FFFFFF);
}
.altrd-hero__cta--outline:hover {
  background: var(--color-altrd-bone, #FFFFFF);
  color: var(--color-altrd-ink, #000000);
}

@media (prefers-reduced-motion: no-preference) {
  .altrd-hero__eyebrow,
  .altrd-hero__heading,
  .altrd-hero__subheading,
  .altrd-hero__cta {
    animation: altrd-fade-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .altrd-hero__heading    { animation-delay: 0.08s; }
  .altrd-hero__subheading { animation-delay: 0.18s; }
  .altrd-hero__cta        { animation-delay: 0.28s; }
}

@keyframes altrd-fade-up {
  from { opacity: 0; transform: translateY(2rem); }
  to   { opacity: 1; transform: translateY(0); }
}

/* === Pull hero behind sticky header so glass blur has content at page load === */
.shopify-section:first-of-type .altrd-hero {
  margin-top: calc(-1 * var(--altrd-header-h, 6.5rem));
  min-height: calc(100svh + var(--altrd-header-h, 6.5rem));
}

.shopify-section:first-of-type .altrd-hero__inner {
  padding-top: calc(var(--altrd-header-h, 6.5rem) + 5rem);
}

@media screen and (max-width: 749px) {
  .shopify-section:first-of-type .altrd-hero__inner {
    padding-top: calc(var(--altrd-header-h, 5rem) + 3.5rem);
  }
}
{% endstylesheet %}

{% javascript %}
document.querySelectorAll('.altrd-hero__video-wrap video').forEach(function(v) {
  v.setAttribute('playsinline', '');
});

// Measure header-group height and set --altrd-header-h CSS var
// so the hero can slide behind the glass header precisely
(function() {
  function setHeaderH() {
    var hg = document.querySelector('.shopify-section-group-header-section');
    if (hg) {
      document.documentElement.style.setProperty('--altrd-header-h', hg.offsetHeight + 'px');
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setHeaderH);
  } else {
    setHeaderH();
  }
  window.addEventListener('resize', setHeaderH);
})();
{% endjavascript %}

{% schema %}
{
  "name": "ALTRD — Hero",
  "class": "altrd-hero-section",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Vol. I — Compound"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Built different. On purpose."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Streetwear for the builder generation. Every piece carries an idea — wear your mindset."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the drop"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "hivis",   "label": "Hi-vis (yellow)" },
        { "value": "bone",    "label": "Bone (light)" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "hivis"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Centre" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "min_height",
      "label": "Section height",
      "options": [
        { "value": "adapt",  "label": "Adapt to content" },
        { "value": "small",  "label": "Small (50vh)" },
        { "value": "medium", "label": "Medium (70vh)" },
        { "value": "large",  "label": "Large (90vh)" },
        { "value": "full",   "label": "Full screen" }
      ],
      "default": "large"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video",
      "info": "Autoplays muted and looped. Upload an MP4 for best compatibility. Falls back to image on reduced-motion preference."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Used as fallback when no video is set, or as the reduced-motion poster."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 85,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 55
    }
  ],
  "presets": [
    {
      "name": "ALTRD — Hero",
      "settings": {
        "eyebrow": "Vol. I — Compound",
        "heading": "Built different. On purpose.",
        "subheading": "Streetwear for the builder generation. Every piece carries an idea — wear your mindset.",
        "cta_label": "Shop the drop",
        "cta_style": "hivis",
        "text_position": "left",
        "min_height": "large"
      }
    }
  ]
}
{% endschema %}
